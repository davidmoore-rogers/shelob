# Database
DATABASE_URL=postgresql://polaris:polaris@localhost:5432/polaris

# pg connection-pool size for the Prisma driver adapter. Default 25 — covers
# the monitor worker pool + HTTP handlers + background jobs at small/medium
# scale. Raise this when running with many monitored assets (rule of thumb:
# 2× expected concurrent monitor workers + 10–20 for HTTP). The DB itself
# must allow at least this many connections (Postgres `max_connections`).
# DATABASE_POOL_SIZE=25

# Monitor worker concurrency. Defaults are CPU-aware: light loop (probe +
# fastFiltered) uses cpus().length * 2 (clamped 8..64); heavy loop (telemetry
# + systemInfo) uses cpus().length (clamped 4..32). Override either when
# benchmarking shows the default is too generous (small VM, shared host) or
# too tight (many monitored assets, idle CPUs). Cursor-queue mode only.
# POLARIS_PROBE_CONCURRENCY=
# POLARIS_HEAVY_CONCURRENCY=

# pg-boss worker localConcurrency (only consulted when the monitor queue is
# in "pgboss" mode — flip via the Maintenance tab's [Enable on next restart]
# button). Architecture: 24 dedicated workers per queue (4 × 24 = 96 slots)
# plus a floating pool of 32 workers that polls all four queues in priority
# order (probe > fastFiltered > telemetry > systemInfo). Total ceiling is
# 128 — same as the previous flat 32×4 — but the floating pool shifts to
# wherever the backlog is. Raise these alongside DATABASE_POOL_SIZE.
# POLARIS_MONITOR_PROBE_WORKERS=24
# POLARIS_MONITOR_FAST_WORKERS=24
# POLARIS_MONITOR_HEAVY_WORKERS=24
# POLARIS_MONITOR_FLOATING_WORKERS=32

# pg-boss internal connection pool size (pgboss mode only). pg-boss manages
# its own pg.Pool separate from Prisma's DATABASE_POOL_SIZE pool. Default 20
# — sized for the default worker count (max(16, min(64, cpus().length × 4))
# per queue). Raise alongside DATABASE_POOL_SIZE when connections peak near
# max_connections during monitoring-heavy or discovery-heavy periods.
# POLARIS_PGBOSS_POOL_SIZE=20

# TimescaleDB compression window (days). When the timescaledb extension is
# installed, monitoring sample tables become hypertables and chunks older
# than this many days are compressed (typically 10-30× space reduction).
# Default 7 keeps the 1h / 24h / 7d UI chart ranges on uncompressed chunks
# for instant queries; bump to 14 or 30 if you want even faster recent-history
# charts at the cost of more disk, or drop to 1 to maximize disk savings on
# tight-disk hosts. 0 disables compression. Has no effect when the extension
# is not installed.
# TIMESCALE_COMPRESS_AFTER_DAYS=7

# App
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Session secret — required when NODE_ENV=production (server refuses to boot
# without it). Generate a long random value, e.g. `openssl rand -hex 64`.
SESSION_SECRET=change-me-before-production

# Reverse-proxy trust — leave UNSET when the app is exposed directly to the
# internet. Setting this while not behind a proxy lets clients spoof their IP
# via X-Forwarded-For and bypass the login rate limiter. Enable only when
# running behind nginx/Caddy/Cloudflare/an ALB/etc:
#   TRUST_PROXY=1              # trust the nearest one hop
#   TRUST_PROXY=loopback       # trust 127.0.0.1 / ::1
#   TRUST_PROXY=10.0.0.0/8     # trust a specific CIDR
# See https://expressjs.com/en/guide/behind-proxies.html
# TRUST_PROXY=

# Health check token — when set, /health requires `Authorization: Bearer <token>`.
# The first-run setup wizard auto-generates this so the endpoint isn't
# exposed open out of the box. Generate a fresh value with
# `openssl rand -hex 32`. Clear the value if you genuinely need an open
# endpoint (e.g. some L4 health probes can't carry a header); the
# Maintenance tab will surface a warning while it is unset.
# HEALTH_TOKEN=

# Prometheus metrics token — when set, /metrics requires
# `Authorization: Bearer <token>`. Auto-generated by the first-run setup
# wizard because the endpoint leaks fleet size, monitor health by status,
# monitor pass duration, and queue depth as recon data — leaving it open
# on a public deployment is a meaningful information leak. Generate a
# fresh value with `openssl rand -hex 32`. Clear the value to expose
# the endpoint open (the Maintenance tab will surface a warning).
# METRICS_TOKEN=

# Public URL the Polaris Agent should call back to. Stamped into
# /etc/polaris-agent/agent.conf (or %ProgramData%\Polaris\agent\agent.conf)
# when an operator installs the agent on a remote host. REQUIRED for any
# reverse-proxy / TLS-termination-upstream topology — the agent runs on a
# remote host that almost certainly can't reach the upstream Polaris's
# internal address, so without this it tries the upstream URL and fails
# the TLS handshake. Single-box installs default to https://localhost:<PORT>
# which is fine for testing but useless for any real install.
# POLARIS_PUBLIC_URL=https://polaris.example.com:3000

# Public hostname the agent should embed in agent.conf when POLARIS_PUBLIC_URL
# isn't set. Less general than POLARIS_PUBLIC_URL (no scheme, no port
# override), but covers the simple "just point agents at this hostname"
# case. POLARIS_PUBLIC_URL wins when both are set.
# POLARIS_PUBLIC_HOST=polaris.example.com
