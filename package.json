{
  "name": "shelob",
  "version": "1.0.1",
  "description": "Shelob — subnet & IP address management, spinning your network into a web",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "demo": "node demo.mjs",
    "test:fmg": "node scripts/test-fmg.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/client": "^5.14.0",
    "bcrypt": "^6.0.0",
    "cidr-tools": "^7.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ip-cidr": "^3.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "netmask": "^2.0.2",
    "pg": "^8.20.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.2",
    "@types/netmask": "^2.0.6",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.2",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^4.1.4",
    "prisma": "^5.14.0",
    "supertest": "^7.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
