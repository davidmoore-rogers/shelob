{
  "name": "polaris",
  "version": "1.0.0",
  "description": "Polaris — subnet & IP address management, the fixed reference point for your network",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force && npm run db:seed",
    "demo": "node demo.mjs",
    "test:fmg": "node scripts/test-fmg.mjs",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@node-saml/node-saml": "^5.1.0",
    "@prisma/client": "^6.19.3",
    "cidr-tools": "^7.0.0",
    "compression": "^1.8.1",
    "connect-pg-simple": "^10.0.0",
    "express": "^5.0.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "helmet": "^8.1.0",
    "ip-cidr": "^3.1.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "ldapts": "^8.1.7",
    "multer": "^2.1.1",
    "net-snmp": "^3.26.3",
    "netmask": "^2.0.2",
    "otpauth": "^9.5.0",
    "pg": "^8.20.0",
    "pino": "^9.2.0",
    "pino-pretty": "^11.2.1",
    "qrcode": "^1.5.4",
    "ssh2": "^1.17.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/connect-pg-simple": "^7.0.3",
    "@types/express": "^5.0.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^2.1.0",
    "@types/net-snmp": "^3.23.0",
    "@types/netmask": "^2.0.6",
    "@types/node": "^20.14.2",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@types/supertest": "^6.0.2",
    "@types/xml2js": "^0.4.14",
    "@vitest/coverage-v8": "^4.1.4",
    "cytoscape": "^3.30.2",
    "cytoscape-dagre": "^2.5.0",
    "dagre": "^0.8.5",
    "leaflet": "^1.9.4",
    "leaflet.markercluster": "^1.5.3",
    "prisma": "^6.19.3",
    "supertest": "^7.0.0",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
