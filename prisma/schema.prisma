// Manufacturer alias map. Normalizes inbound manufacturer strings (from OUI
// lookups, discovery, manual entry, MIB upload) to a single canonical form so
// "Fortinet, Inc." and "Fortinet" don't split into two entries everywhere.
// `alias` is stored lowercased+trimmed for case-insensitive match; `canonical`
// is stored as-typed and is what gets written into Asset.manufacturer /
// MibFile.manufacturer at every write site (via the Prisma extension in db.ts).
// Admin-editable from Server Settings → Identification → Manufacturer Aliases.
model ManufacturerAlias {
  id        String   @id @default(uuid())
  alias     String   @unique // lowercased + trimmed input string
  canonical String // canonical manufacturer name (as-typed)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([canonical])
  @@map("manufacturer_aliases")
}

// SNMP MIB modules uploaded by an admin from Server Settings → Identification.
// Used to resolve vendor-specific OIDs during monitoring. MIB text is stored
// inline (MIBs are small — typically <100 KB) and validated on upload by a
// minimal SMI parser that extracts the module name + IMPORTS dependencies.
// Anything that doesn't match the SMI grammar is rejected, which also rules
// out arbitrary text or binary uploads.
//
// scope = "generic" when manufacturer is null (loaded for every probe);
// scope = "device"  when manufacturer is set (loaded only for matching assets).
// model = null means "applies to all models from this manufacturer".
model MibFile {
  id           String   @id @default(uuid())
  filename     String // original upload filename, e.g. "CISCO-PROCESS-MIB.txt"
  moduleName   String // parsed from "<NAME> DEFINITIONS ::= BEGIN"
  manufacturer String? // null = generic/shared MIB
  model        String? // null = applies to all models from manufacturer
  // assetId pins this MIB to ONE specific asset — the most-specific scope
  // tier in the per-asset resolution priority (asset → model → manufacturer
  // → generic → seed). Used when one device of a fleet runs a different
  // firmware that exposes a vendor-specific symbol the rest doesn't.
  assetId      String?
  asset        Asset?   @relation("MibFilesOnAsset", fields: [assetId], references: [id], onDelete: SetNull)
  contents     String   @db.Text // raw MIB text
  imports      String[] @default([]) // module names referenced via IMPORTS ... FROM
  size         Int // byte length of contents
  notes        String?  @db.Text
  uploadedBy   String?
  uploadedAt   DateTime @default(now())

  profileMetricDefaults   ManufacturerProfileMetric[]         @relation("ManufacturerProfileMetricDefaultMib")
  profileMetricOverrides  ManufacturerProfileMetricOverride[] @relation("ManufacturerProfileMetricOverrideMib")
  customWidgets           ManufacturerCustomWidget[]          @relation("ManufacturerCustomWidgetMib")

  @@unique([manufacturer, model, moduleName])
  @@index([manufacturer, model])
  @@index([moduleName])
  @@index([assetId])
  @@map("mib_files")
}

// Operator-editable per-manufacturer telemetry profile. Replaces the
// hardcoded VENDOR_TELEMETRY_PROFILES constant at runtime — discovery seeds
// these rows from the constant on first boot (idempotent), and the
// monitoring path resolves through the DB rows from then on. The constant
// stays as a fresh-install fallback for hosts whose seeding hasn't run yet.
//
// Match key is the alias-canonicalized manufacturer string; only one row
// per canonical manufacturer. Per-model exceptions (e.g. Fortinet's
// FortiSwitch / FortiAP variants under the Fortinet profile) live as
// `ManufacturerProfileMetricOverride` rows nested under each metric row.
model ManufacturerProfile {
  id           String   @id @default(uuid())
  manufacturer String   @unique // canonical form via ManufacturerAlias map
  createdBy    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  metrics ManufacturerProfileMetric[]
  widgets ManufacturerCustomWidget[]

  @@map("manufacturer_profiles")
}

// One row per System-tab metric the profile owns (cpu / memory / temperature
// / interfaces / lldp / storage / wirelessStations). `defaultSymbol` +
// `defaultMibId` describe the symbol Polaris walks for this metric on every
// asset that resolves through this profile, unless a per-model override row
// (`ManufacturerProfileMetricOverride`) matches `Asset.model` first.
//
// Null defaultSymbol = use the built-in seed for this metric (i.e. the
// hardcoded VENDOR_TELEMETRY_PROFILES entry's value for this manufacturer);
// null defaultMibId = built-in seed scope. `defaultType` is "scalar" or
// "table" and is what `collectTelemetrySnmp` uses to decide between GET .0
// and walk-the-subtree. `defaultTransform` is the optional value-transform
// applied after the SNMP value lands (Celsius↔Fahrenheit, bytes→MB, etc.).
model ManufacturerProfileMetric {
  id               String   @id @default(uuid())
  profileId        String
  profile          ManufacturerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  metricKey        String   // "cpu" | "memory" | "temperature" | "interfaces" | "lldp" | "storage" | "wirelessStations"
  defaultSymbol    String?
  defaultMibId     String?
  defaultMib       MibFile? @relation("ManufacturerProfileMetricDefaultMib", fields: [defaultMibId], references: [id], onDelete: SetNull)
  // Operator-pinned standard MIB key (e.g. "std:lldp", "std:host-resources").
  // Mutually exclusive with defaultMibId in the UI — picking a standard MIB
  // sets this and clears defaultMibId, and vice versa. Display-only at probe
  // time: the resolver still walks asset → model → vendor → generic → seed.
  // Lets the Manufacturer Profile table show a meaningful MIB label for
  // metrics whose symbol comes from a built-in seed instead of "seed".
  defaultMibStdKey String?
  defaultType      String   @default("scalar") // "scalar" | "table"
  defaultTransform String?  // "celsius_to_fahrenheit" | "bytes_to_mb" | ... | null
  // Multi-OID composition. Today consulted only when metricKey="memory" — lets
  // operators express the bytes-form memory shape (Used+Total or Used+Free) in
  // the editable profile, matching what the hardcoded VENDOR_TELEMETRY_PROFILES
  // baseline can already do for FortiSwitch. When present, takes precedence
  // over defaultSymbol. Shape: { shape: "percent" | "bytes_used_total" |
  // "bytes_used_free", usedSymbol?, totalSymbol?, freeSymbol?, pctSymbol? }.
  // Validated by manufacturerProfileService.parseMemoryComposition.
  composition      Json?

  overrides ManufacturerProfileMetricOverride[]

  @@unique([profileId, metricKey])
  @@index([defaultMibId])
  @@map("manufacturer_profile_metrics")
}

// Per-model exception inside a manufacturer's metric row. Evaluated in
// `order` (lower wins); first override whose `modelPattern` regex matches
// `Asset.model` is the effective symbol/mib/type/transform for that asset's
// SNMP walk. No matches = the parent metric row's default* is used.
model ManufacturerProfileMetricOverride {
  id           String   @id @default(uuid())
  metricRowId  String
  metricRow    ManufacturerProfileMetric @relation(fields: [metricRowId], references: [id], onDelete: Cascade)
  modelPattern String   // regex tested against Asset.model
  symbol       String
  mibId        String?
  mib          MibFile? @relation("ManufacturerProfileMetricOverrideMib", fields: [mibId], references: [id], onDelete: SetNull)
  // Same display-only standard-MIB hint as the parent metric row. See
  // ManufacturerProfileMetric.defaultMibStdKey.
  mibStdKey    String?
  type         String   @default("scalar") // "scalar" | "table"
  transform    String?
  order        Int      @default(0)
  // Multi-OID composition — mirrors the parent metric row's column. Same
  // shape, same precedence rule: when present, takes precedence over `symbol`.
  // Lets a per-model override carry its own memory Shape (e.g. parent metric
  // = bytes_used_total, override for a specific model = percent, or vice versa).
  composition  Json?

  @@index([metricRowId, order])
  @@index([mibId])
  @@map("manufacturer_profile_metric_overrides")
}

// Operator-defined custom widget that Slice 7's Custom MIB tab on the
// asset details modal will render for every asset whose alias-normalized
// manufacturer matches this profile (and whose model satisfies the
// optional `modelPattern` gate). The widget walks `symbol` against `mibId`
// at the cadence dispatcher's `customWidget` interval and renders the
// result per `widgetType` (gauge / line / table). `displayOptions` is the
// type-specific blob (gauge min/max + thresholds, line aggregate/unit,
// table column list / decode rules).
model ManufacturerCustomWidget {
  id             String   @id @default(uuid())
  profileId      String
  profile        ManufacturerProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  name           String   // operator-set label, e.g. "Connected Wireless Clients"
  symbol         String
  mibId          String
  mib            MibFile  @relation("ManufacturerCustomWidgetMib", fields: [mibId], references: [id])
  type           String   @default("scalar") // "scalar" | "table" (auto-detected; operator can override)
  widgetType     String   // "gauge" | "line" | "table"
  transform      String?
  displayOptions Json     @default("{}")
  order          Int      @default(0)
  modelPattern   String?  // optional per-model gating
  createdBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([profileId, order])
  @@index([mibId])
  @@map("manufacturer_custom_widgets")
}

model Conflict {
  id         String @id @default(uuid())
  entityType String @default("reservation") // "reservation" | "asset"

  // Reservation conflicts (discovery proposes changes to a manually-created reservation)
  reservationId String?
  reservation   Reservation? @relation(fields: [reservationId], references: [id], onDelete: Cascade)

  // Asset conflicts (discovery proposes an asset that collides by hostname with an existing untagged asset)
  assetId String?
  asset   Asset?  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  integrationId String?

  // Reservation-conflict proposed values
  proposedHostname   String?
  proposedOwner      String?
  proposedProjectRef String?
  proposedNotes      String? @db.Text
  proposedSourceType String? // Required for reservations, null for assets

  // Asset-conflict proposed values
  proposedDeviceId    String? // Entra deviceId — used to de-dupe conflicts across discovery runs
  proposedAssetFields Json? // Full Entra/Intune snapshot: hostname, serial, mac, model, manufacturer, os, osVersion, assignedTo, chassisType, complianceState, trustType

  conflictFields String[]

  status     ConflictStatus @default(pending)
  resolvedBy String?
  resolvedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reservationId])
  @@index([assetId])
  @@index([entityType])
  @@index([status])
  @@index([integrationId])
  @@index([proposedDeviceId])
  @@map("conflicts")
}

// Sighting log: every (asset, FortiGate) pair where the FortiGate has handed
// out a DHCP lease/reservation to the asset, attributed an interface IP, or
// owned a VIP that points at the asset's IP. Populated during the FMG /
// FortiGate discovery sync — only DHCP-level evidence is recorded (transit
// sightings via monitor-system-info are intentionally excluded). Drives the
// quarantine fan-out: pushing a quarantine on an asset writes the asset's
// MACs to every FortiGate in this list whose lastSeen falls within the
// configured `quarantine.sightingMaxAgeDays` setting.
model AssetFortigateSighting {
  id              String       @id @default(uuid())
  assetId         String
  asset           Asset        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  integrationId   String?
  integration     Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)
  fortigateDevice String // matches Subnet.fortigateDevice / Asset.learnedLocation
  source          String // "dhcp_lease" | "dhcp_reservation" | "interface_ip" | "vip"
  ipAddress       String? // IP last seen on this FortiGate (lease/reservation IP); nullable for rows recorded before this column existed
  firstSeen       DateTime     @default(now())
  lastSeen        DateTime     @default(now())

  @@unique([assetId, fortigateDevice])
  @@index([assetId])
  @@index([assetId, lastSeen])
  @@index([integrationId])
  @@index([fortigateDevice])
  @@map("asset_fortigate_sightings")
}

// Bearer-token authentication for external callers (e.g. SIEM systems) that
// need to invoke specific Polaris endpoints without a UI session. Tokens are
// scoped to a fixed list of capabilities (currently: "assets:quarantine",
// "assets:read") so a leaked token can't be elevated into a full admin login.
//
// The raw token is only ever shown once at creation; tokenHash is argon2id
// of the raw token, and tokenPrefix stores the first 8 chars for display in
// the management UI ("polaris_xxxxxxxx…"). revokedAt soft-deletes the row
// (preferred over hard-delete so audit history points at a real id even
// after revocation). Optional expiresAt enforces server-side expiry.
model ApiToken {
  id             String    @id @default(uuid())
  name           String    @unique
  tokenHash      String // argon2id hash of the raw token
  tokenPrefix    String // first 8 chars of the raw token for UI display
  scopes         String[]  @default([]) // e.g. ["assets:quarantine", "assets:read"]
  // Integration ids this token may operate against. Required + non-empty for
  // tokens with `assets:quarantine`; ignored for read-only scopes. Tokens
  // with this set will only quarantine/release/verify against sightings whose
  // originating integration id is in this list — so a token minted for "Site
  // A FortiGate" can never accidentally push to Site B's gateway.
  integrationIds String[]  @default([])
  createdBy      String // username of the admin who minted the token
  createdAt      DateTime  @default(now())
  expiresAt      DateTime?
  lastUsedAt     DateTime?
  lastUsedIp     String?
  revokedAt      DateTime?
  revokedBy      String?

  @@index([revokedAt])
  @@index([expiresAt])
  @@map("api_tokens")
}

// Per-discovery-source view of an asset. The unified `Asset` row remains the
// stable id everything else FKs to (monitoring, ip-history, sightings,
// quarantine); AssetSource rows hang off Asset and capture what each source
// independently said about the device. The merged display fields on Asset are
// a projection across these rows — phase 1 just shadow-writes them from the
// existing assetTag / "sid:" / "ad-guid:" tags so the table is populated and
// shaped before discovery cutover (phase 2).
//
// Phase-1 sourceKind values: "entra" | "ad" | "fortigate-firewall" | "manual"
// Future values (phase 2 cutover): "intune" | "fortiswitch" | "fortiap"
//                                  | "fortigate-dhcp-host" | ...
//
// `(sourceKind, externalId)` is the natural dedupe key — entra.deviceId,
// ad.objectGUID, fortigate-firewall.serial. Manual sources use the Asset.id
// itself as externalId so they don't collide.
model AssetSource {
  id      String @id @default(uuid())
  assetId String
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  sourceKind String
  externalId String

  // Originating integration. Null for "manual" rows and for phase-1 inferred
  // rows (e.g. an AD source recovered from an "ad-guid:" tag where the AD
  // integration linkage is no longer reconstructable).
  integrationId String?
  integration   Integration? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  // Source-shaped raw observation blob — see CLAUDE.md "Per-source observed
  // shapes." Stays as the source said it; the Asset row is the merged
  // projection across all sources.
  observed Json @default("{}")

  // True when synthesized by the phase-1 backfill from legacy assetTag /
  // "sid:" / "ad-guid:" tags rather than discovered fresh. Cleared when the
  // next real discovery run replaces the row with truth.
  inferred Boolean @default(false)

  // syncedAt  = last successful refresh from this source (drives staleness)
  // lastSeen  = last time this source reported the device as active
  // firstSeen = when Polaris first recorded this source
  syncedAt  DateTime?
  firstSeen DateTime  @default(now())
  lastSeen  DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sourceKind, externalId])
  @@index([assetId])
  @@index([sourceKind])
  @@index([integrationId])
  @@map("asset_sources")
}

// Persistent parent→child edges of the Fortinet infrastructure dependency
// DAG. Drives dependency-aware monitoring suppression: when ALL of an
// asset's effective parents are confirmed down (or themselves suppressed),
// telemetry / systemInfo / fastFiltered cadences pause and the
// response-time probe slows to 2× the resolved interval. Multi-parent rows
// model MCLAG / dual-homed switches; "all-down" semantics mean a redundant
// uplink keeps an asset polling normally.
//
// Resolution rule: if any source="override" rows exist for an asset, those
// are its effective parents and the computed set is ignored; otherwise the
// source="computed" set is used. Operators get full control (admin-only
// override endpoints) without losing the computed audit trail.
//
// The recomputeDependencyTree helper rebuilds the source="computed" rows
// at end of every FMG/FortiGate discovery cycle (Phase 2d in
// syncDhcpSubnets, plus the standalone FortiGate path). source="override"
// rows are operator-managed and never touched by the recompute.
//
// detectedVia distinguishes the signal that produced a computed row:
//   - "controller" — Asset.fortinetTopology.controllerFortigate / parentSwitch
//   - "interface"  — interfaceTopologyService inferred edge (FortiLink /
//                    MCLAG aggregate naming)
//   - "lldp"       — AssetLldpNeighbor.matchedAssetId fallback
//   - "manual"     — operator override (only present on source="override")
model AssetDependencyParent {
  id            String @id @default(uuid())
  assetId       String
  asset         Asset  @relation("AssetDependencyChild", fields: [assetId], references: [id], onDelete: Cascade)
  parentAssetId String
  parent        Asset  @relation("AssetDependencyParent", fields: [parentAssetId], references: [id], onDelete: Cascade)

  source      String // "computed" | "override"
  detectedVia String // "controller" | "interface" | "lldp" | "manual"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Same (child, parent) pair may exist in BOTH "computed" and "override"
  // form simultaneously — a deliberate override that pins the same parent the
  // recompute would have picked anyway should still register on the
  // override-takes-precedence rule. Including source in the unique key lets
  // both rows coexist; the read-time resolver in dependencyTreeService groups
  // by source and applies override-wins.
  @@unique([assetId, parentAssetId, source])
  @@index([assetId])
  @@index([parentAssetId])
  @@index([source])
  @@map("asset_dependency_parents")
}

// Operator-uploaded device icons used by the Device Map's topology graph
// (and potentially other render surfaces in the future) to represent
// specific hardware models or asset types. Resolution priority at render
// time is most-specific-wins:
//   1. scope="model" key="<manufacturer>/<model>" — e.g. "Fortinet/FortiGate-91G"
//   2. scope="model" key="<model>"                — manufacturer-agnostic match
//   3. scope="type"  key=<assetType>              — type-level fallback
//   4. no row → frontend falls back to the default node style.
//
// Image bytes are stored inline (one-request fetch via the dedicated
// /device-icons/:id/image endpoint, which serves the raw bytes with
// proper Content-Type + Cache-Control). Hard cap on size is enforced at
// upload time in deviceIconService — keeps backups bounded.
model DeviceIcon {
  id         String   @id @default(uuid())
  scope      String
  key        String
  filename   String
  mimeType   String
  data       Bytes
  size       Int
  uploadedBy String?
  uploadedAt DateTime @default(now())

  @@unique([scope, key])
  @@index([scope])
  @@map("device_icons")
}

// Polaris Agent installation record. One row per (asset × agent install).
// Independent of AssetSource — installing an agent doesn't change discovery
// identity, it just adds a new polling transport (`responseTimePolling="agent"`
// etc.) that the agent itself satisfies by pushing samples back to Polaris.
//
// Lifecycle (drives `installStatus`):
//   Install:    pending → uploading → enrolling → active
//                                         ↘ failed (install_failed event, row stays for retry)
//   Uninstall:  active → uninstalling → (row hard-deleted on success)
//                              ↘ uninstall_failed (row stays; operator retries or force-removes)
//   Force:      any → (row hard-deleted, force_removed event)
//   Reinstall:  uninstall + install run back-to-back; old row deleted, new row created
//
// Two token columns: `enrollmentToken*` is one-shot (10-min TTL) and NULLed
// the moment the agent POSTs /api/v1/agents/enroll successfully; `bearer*` is
// the long-lived per-agent token issued at that moment, used for every
// subsequent /samples / /config / /heartbeat call and for the outbound
// WebSocket. Both stored as argon2id hashes + a short prefix for indexed
// lookup, matching the ApiToken pattern. The bearer is bound to this asset
// via the @unique([assetId]) constraint — defense against stolen-bearer
// cross-asset reuse (handler stamps the bearer's assetId, ignoring the body).
//
// `serverCertFingerprint` is the SHA-256 of the running Polaris HTTPS leaf
// cert at install time, captured by agentInstallService and baked into the
// host's agent.conf. The agent's TLS client uses this as a pin — it does NOT
// trust system roots. POST /enroll cross-checks: client reports the cert it
// observed, server matches against this column.
model ManagedAgent {
  id      String @id @default(uuid())
  assetId String @unique
  asset   Asset  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  osPlatform   String // "linux" | "darwin" | "windows"
  arch         String // "amd64" | "arm64"
  agentVersion String? // semver reported on enroll; null until first enroll
  installedBy  String // username of operator who clicked Install
  installedAt  DateTime @default(now())

  // Credential used at install time. Stored so the default DELETE path
  // (remote uninstall via the same SSH/WinRM creds) doesn't have to ask
  // the operator to re-pick it. Cleared on credential deletion via
  // SetNull so an orphaned ManagedAgent doesn't block the credential's
  // removal; the operator falls back to ?force=true in that case.
  installCredentialId String?
  installCredential   Credential? @relation("AgentInstallCredential", fields: [installCredentialId], references: [id], onDelete: SetNull)

  installStatus String  @default("pending") // see lifecycle comment above
  installError  String? // captured stderr / exception message on failure

  // One-shot enrollment token. NULLed atomically when /enroll succeeds.
  enrollmentTokenHash   String?
  enrollmentTokenPrefix String?
  enrollmentExpiresAt   DateTime?

  // Long-lived bearer (argon2id, prefix-indexed). Wire format same as
  // ApiToken: `polaris_<32-char-base62>`. Bound to assetId at issuance.
  bearerHash      String?
  bearerPrefix    String?
  bearerIssuedAt  DateTime?
  bearerRevokedAt DateTime?

  lastSeenAt       DateTime?
  lastSeenIp       String?
  wsConnectedAt    DateTime?
  wsDisconnectedAt DateTime?

  // SHA-256 of the leaf cert as `sha256:<hex>`. Pinned at install; checked
  // server-side at enrollment, client-side on every subsequent TLS handshake.
  serverCertFingerprint String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([installStatus])
  @@index([bearerPrefix])
  @@index([enrollmentTokenPrefix])
  @@map("managed_agents")
}

// Geocode result cache. Populated by `geocoderService.geocode()` when
// discovery falls back from a malformed CMDB coord to the FortiGate's SNMP
// sysLocation string. Negative results (no geocoder hit) are stored too so
// gibberish location strings don't repeatedly hit the upstream provider.
//
// `query` is the normalized lookup key (trim + collapse whitespace +
// lowercase) and is unique. `displayQuery` preserves the original casing
// for UI display.
//
// `ttlExpiresAt` defaults to fetchedAt + 90 days; expired rows are refetched
// on the next discovery cycle that touches that location string.
model GeocodeCache {
  id           String   @id @default(uuid())
  query        String   @unique
  displayQuery String
  latitude     Float?
  longitude    Float?
  provider     String // "nominatim"
  fetchedAt    DateTime @default(now())
  ttlExpiresAt DateTime

  @@index([ttlExpiresAt])
  @@map("geocode_cache")
}
