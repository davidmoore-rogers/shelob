// Prisma Schema — Polaris (Subnet & IP Address Management)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum IpVersion {
  v4
  v6
}

enum SubnetStatus {
  available
  reserved
  deprecated
}

enum ReservationStatus {
  active
  expired
  released
}

enum ReservationSourceType {
  manual
  dhcp_reservation
  dhcp_lease
  interface_ip
  vip
  fortiswitch
  fortinap
  fortimanager
  fortigate
  dns_resolved
}

enum ConflictStatus {
  pending
  accepted
  rejected
}

// UserRole enum retired — replaced by the Role table below. Role identity
// + permission matrix now live in `Role` and are joined into User via
// `User.roleId`. See "Roles / RBAC" in CLAUDE.md for the access semantics.

// ─── Models ───────────────────────────────────────────────────────────────────

model IpBlock {
  id          String    @id @default(uuid())
  name        String
  cidr        String    @unique
  ipVersion   IpVersion
  description String?   @db.Text
  tags        String[]  @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets Subnet[]

  @@index([ipVersion])
  @@map("ip_blocks")
}

model Subnet {
  id      String  @id @default(uuid())
  blockId String
  block   IpBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  cidr    String
  name    String
  purpose String?      @db.Text
  status  SubnetStatus @default(available)
  vlan    Int?
  tags    String[]     @default([])

  discoveredBy    String?
  integration     Integration? @relation(fields: [discoveredBy], references: [id], onDelete: SetNull)
  fortigateDevice String?
  createdBy       String?

  // Bumped whenever discovery touches this subnet — both the integration-wide
  // discoverDhcpSubnets pass and the per-subnet Refresh action stamp it.
  // Drives the "Discovered N minutes ago" line in the IP panel slide-in.
  lastDiscoveredAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reservations Reservation[]

  @@index([blockId])
  @@index([blockId, status])
  @@index([cidr])
  @@index([status])
  @@index([discoveredBy])
  @@index([createdBy])
  @@map("subnets")
}

model Reservation {
  id       String @id @default(uuid())
  subnetId String
  subnet   Subnet @relation(fields: [subnetId], references: [id], onDelete: Cascade)

  ipAddress       String?
  hostname        String?
  owner           String?
  projectRef      String?
  expiresAt       DateTime?
  notes           String?               @db.Text
  status          ReservationStatus     @default(active)
  sourceType      ReservationSourceType @default(manual)
  createdBy       String?
  conflictMessage String?
  vipInfo         Json?

  // DHCP reservation push to FortiGate. Populated only when an FMG integration
  // with `pushReservations=true` discovered this subnet AND the reservation is
  // sourceType=manual. macAddress is the MAC sent to the device (DHCP
  // reservations are MAC→IP). pushedScopeId / pushedEntryId pin the row on the
  // FortiGate so unpush hits the exact entry without re-resolving by IP.
  // pushStatus values: "synced" (verified on device), "drift" (was synced,
  // missing on rediscovery). On create-time push failure the entire reservation
  // create aborts and no row is persisted, so "failed" is not a stored state.
  macAddress    String?
  pushedToId    String?
  pushedTo      Integration? @relation("ReservationPushedTo", fields: [pushedToId], references: [id], onDelete: SetNull)
  pushedScopeId Int?
  pushedEntryId Int?
  pushStatus    String?
  pushedAt      DateTime?
  pushError     String?      @db.Text

  // Stale-reservation detection. lastSeenLeased is bumped during DHCP
  // discovery whenever /api/v2/monitor/system/dhcp confirms the reservation's
  // IP is actively held by a client right now. staleNotifiedAt tracks the
  // most recent time the flagStaleReservations job emitted a `reservation.stale`
  // Event for this row, so the next nightly run doesn't re-fire the same
  // alert until the threshold is recrossed (lastSeenLeased advances).
  // staleSnoozedUntil is set by the operator-driven Snooze action on the
  // Alerts panel; while it is in the future, the row is suppressed from the
  // alert list and the job won't re-fire. Cleared when discovery sees the IP
  // active again so a re-snoozed reservation that comes back online
  // re-arms cleanly.
  // staleIgnored is the network-admin/admin-driven "permanently ignore"
  // action — when true, the row is suppressed from the alert list and the
  // job won't re-fire forever, until an admin explicitly un-ignores. Unlike
  // snooze, this flag is NOT cleared by discovery seeing the IP active
  // again; the operator's intent is durable across online/offline cycles.
  lastSeenLeased    DateTime?
  staleNotifiedAt   DateTime?
  staleSnoozedUntil DateTime?
  staleIgnored      Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conflicts Conflict[]

  @@unique([subnetId, ipAddress, status])
  @@index([subnetId])
  @@index([subnetId, status])
  @@index([owner])
  @@index([projectRef])
  @@index([status])
  @@index([status, expiresAt])
  @@index([expiresAt])
  @@index([createdBy])
  @@index([pushedToId])
  @@map("reservations")
}

model Integration {
  id              String    @id @default(uuid())
  type            String // e.g. "fortimanager"
  name            String // Human-readable label
  config          Json      @default("{}") // Connection settings (host, port, adom, etc.)
  enabled         Boolean   @default(true)
  autoDiscover    Boolean   @default(true)
  pollInterval    Int       @default(4) // Auto-discovery interval in hours (1–24)
  lastTestAt      DateTime?
  lastTestOk      Boolean?
  lastDiscoveryAt DateTime? // Set at the start of each discovery run; used by the scheduler to gate auto-discovery across restarts
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subnets               Subnet[]
  discoveredAssets      Asset[] // Assets stamped with this integration's id (back-relation)
  pushedReservations    Reservation[]            @relation("ReservationPushedTo")
  fortigateSightings    AssetFortigateSighting[] // Back-relation: sightings recorded against this integration's discovered FortiGates
  assetSources          AssetSource[] // Back-relation: per-source asset rows attributed to this integration
  monitorClassOverrides MonitorClassOverride[] // Back-relation: (assetType, integration) override rows

  @@index([type])
  @@index([enabled])
  @@map("integrations")
}

// Credential store for monitoring probes (SNMP, WinRM, SSH).
// Single discriminator table; type-specific fields live in `config` JSON
// following the same plaintext-at-rest + mask-on-API-read pattern as Integration.
//
// config shapes:
//   snmp (v2c):   { version: "v2c", community: string, port?: number }
//   snmp (v3):    { version: "v3", username, authProtocol: "MD5"|"SHA",
//                   authKey, privProtocol: "DES"|"AES"|"none",
//                   privKey?, securityLevel: "noAuthNoPriv"|"authNoPriv"|"authPriv", port?: number }
//   winrm:        { username, password, port?: number, useHttps?: boolean }
//   ssh:          { username, password?, privateKey?, port?: number }
model Credential {
  id        String   @id @default(uuid())
  name      String   @unique
  type      String // "snmp" | "winrm" | "ssh"
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets                       Asset[]                @relation("AssetMonitorCred") // default credential back-relation
  rtAssets                     Asset[]                @relation("AssetRTCred")
  cpuMemoryAssets              Asset[]                @relation("AssetCpuMemCred")
  temperatureAssets            Asset[]                @relation("AssetTempCred")
  interfacesAssets             Asset[]                @relation("AssetInterfacesCred")
  lldpAssets                   Asset[]                @relation("AssetLldpCred")
  customWidgetAssets           Asset[]                @relation("AssetCustomWidgetCred")
  // Back-relations for per-stream class override credentials
  classOverrideRTAssets        MonitorClassOverride[] @relation("ClassOverrideRTCred")
  classOverrideCpuMemAssets    MonitorClassOverride[] @relation("ClassOverrideCpuMemCred")
  classOverrideTempAssets      MonitorClassOverride[] @relation("ClassOverrideTempCred")
  classOverrideIfAssets        MonitorClassOverride[] @relation("ClassOverrideIfCred")
  classOverrideLldpAssets      MonitorClassOverride[] @relation("ClassOverrideLldpCred")
  classOverrideCustomWidgetAssets MonitorClassOverride[] @relation("ClassOverrideCustomWidgetCred")
  // Back-relation for the Polaris Agent install credential (one per
  // ManagedAgent row). SetNull on credential delete so removing a
  // credential doesn't block a stuck agent install — operator falls
  // back to DELETE /assets/:id/agent?force=true in that case.
  managedAgents           ManagedAgent[]         @relation("AgentInstallCredential")

  @@index([type])
  @@map("credentials")
}

// (class + integration) tier of the monitoring settings hierarchy. Each row
// overrides a subset of fields for assets of `assetType` that are scoped to
// `integrationId`. Null `integrationId` represents an override applied to
// "manual" assets — those whose `discoveredByIntegrationId` is null (e.g.
// hand-created assets, or assets whose origin integration was deleted).
//
// Resolution order at probe time:
//   asset override → MonitorClassOverride → Integration.config.monitorSettings
//                                          OR Setting "manualMonitorSettings"
//
// Every settings field is nullable: null = inherit from the tier below.
// Range / sanity validation lives in the route layer (Zod schemas) so the DB
// only enforces shape and uniqueness.
//
// Uniqueness: Postgres treats NULLs as distinct in unique constraints, so the
// `(integrationId, assetType)` index alone won't prevent two `(null, "switch")`
// rows. The service layer enforces uniqueness for the manual-tier case before
// insert. The DB-side index still prevents duplicates within a single
// integration, which is the common case.
model MonitorClassOverride {
  id                        String       @id @default(uuid())
  integrationId             String? // null = override applies to manual-tier (orphan) assets
  integration               Integration? @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  assetType                 String // matches Asset.assetType — "firewall" | "switch" | "access_point" | "server" | "workstation" | "router" | "printer" | "other"
  intervalSeconds           Int?
  failureThreshold          Int?
  probeTimeoutMs            Int?
  // Per-request timeout (ms) for the CPU+memory collector. 1000..120000;
  // null = inherit from the tier below. Applied to FortiOS REST + SNMP
  // session timeouts in collectCpuMemory.
  cpuMemoryTimeoutMs        Int?
  // Per-request timeout (ms) for the temperature collector. 1000..120000;
  // null = inherit. Applied to FortiOS REST + SNMP session timeouts in
  // collectTemperature (ENTITY-SENSOR-MIB walk + the FortiAP scalar
  // fallback).
  temperatureTimeoutMs      Int?
  // Per-request timeout (ms) for the interface / storage / LLDP collector.
  // 1000..120000; null = inherit. Applied to FortiOS REST + SNMP sessions in
  // collectSystemInfo + collectFastFiltered.
  systemInfoTimeoutMs       Int?
  cpuMemoryIntervalSeconds  Int?
  temperatureIntervalSeconds Int?
  systemInfoIntervalSeconds Int?
  // Custom-widget cadence (Slice 7) — drives ManufacturerCustomWidget probes
  // for assets whose manufacturer has at least one widget defined. Default
  // 60s when null at every tier.
  customWidgetIntervalSeconds Int?
  // Custom-widget per-request timeout (ms). null = inherit.
  customWidgetTimeoutMs       Int?
  // ─── Legacy retention columns (single-tier) ─────────────────────────────
  // Phase 1 keeps these alongside the new detail/hourly/daily columns so the
  // resolver + prune layer keep working unchanged until the tier-aware
  // pruning lands. migrateRetentionTiers seeds the corresponding
  // *DetailRetentionDays from these values on first boot. Dropped in a
  // follow-up release once fleet-wide migration is confirmed.
  sampleRetentionDays       Int?
  // Single retention setting shared by AssetTelemetrySample (CPU/memory)
  // AND AssetTemperatureSample. The stream split only affects polling
  // method / cadence / credential / MIB / timeout — sample retention is
  // table-level, so one knob covers both.
  telemetryRetentionDays    Int?
  systemInfoRetentionDays   Int?
  // ─── Tiered retention columns (detail / hourly / daily) ─────────────────
  // Three retention windows per stream — detail (raw samples), hourly
  // (sampleRollup hourly aggregates), daily (sampleRollup daily aggregates).
  // null = inherit from the tier below. Defaults at the manual/integration
  // tier are 7 / 30 / 365 (Phase 1 introduces; phases 2+ start consuming).
  sampleDetailRetentionDays    Int?
  sampleHourlyRetentionDays    Int?
  sampleDailyRetentionDays     Int?
  telemetryDetailRetentionDays Int?
  telemetryHourlyRetentionDays Int?
  telemetryDailyRetentionDays  Int?
  systemInfoDetailRetentionDays Int?
  systemInfoHourlyRetentionDays Int?
  systemInfoDailyRetentionDays  Int?
  // Per-stream polling-method overrides. null = inherit from the integration
  // tier (or the manual tier when integrationId is null). Accepted values:
  // "rest_api" | "snmp" | "winrm" | "ssh" | "icmp". The compatibility-aware
  // resolver silently falls through when the chosen method isn't valid for
  // the asset's source — see CLAUDE.md "Polling-method compatibility matrix".
  responseTimePolling       String?
  cpuMemoryPolling          String?
  temperaturePolling        String?
  interfacesPolling         String?
  lldpPolling               String?
  storagePolling            String?
  customWidgetPolling       String?
  // Per-stream credential overrides (FK to Credential, null = inherit)
  responseTimeCredentialId  String?
  responseTimeCredential    Credential?  @relation("ClassOverrideRTCred", fields: [responseTimeCredentialId], references: [id], onDelete: SetNull)
  cpuMemoryCredentialId     String?
  cpuMemoryCredential       Credential?  @relation("ClassOverrideCpuMemCred", fields: [cpuMemoryCredentialId], references: [id], onDelete: SetNull)
  temperatureCredentialId   String?
  temperatureCredential     Credential?  @relation("ClassOverrideTempCred", fields: [temperatureCredentialId], references: [id], onDelete: SetNull)
  interfacesCredentialId    String?
  interfacesCredential      Credential?  @relation("ClassOverrideIfCred", fields: [interfacesCredentialId], references: [id], onDelete: SetNull)
  lldpCredentialId          String?
  lldpCredential            Credential?  @relation("ClassOverrideLldpCred", fields: [lldpCredentialId], references: [id], onDelete: SetNull)
  customWidgetCredentialId  String?
  customWidgetCredential    Credential?  @relation("ClassOverrideCustomWidgetCred", fields: [customWidgetCredentialId], references: [id], onDelete: SetNull)
  // Per-stream MIB overrides (String: "std:<key>" or uploaded MIB UUID or null)
  responseTimeMibId         String?
  cpuMemoryMibId            String?
  temperatureMibId          String?
  interfacesMibId           String?
  lldpMibId                 String?
  createdAt                 DateTime     @default(now())
  updatedAt                 DateTime     @updatedAt

  @@unique([integrationId, assetType])
  @@index([assetType])
  @@map("monitor_class_overrides")
}

model Event {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  level        String   @default("info") // info, warning, error
  action       String // e.g. "block.created", "integration.discover.started"
  resourceType String? // e.g. "block", "subnet", "integration"
  resourceId   String?
  resourceName String?
  actor        String? // username that triggered the event
  message      String   @db.Text
  details      Json? // Optional extra context (error stack, diff, etc.)

  @@index([timestamp])
  @@index([action])
  @@index([resourceType])
  @@index([level])
  @@map("events")
}

enum AssetStatus {
  active
  maintenance
  decommissioned
  storage
  disabled
  quarantined
}

enum AssetType {
  server
  switch
  router
  firewall
  workstation
  printer
  access_point
  other
}

model Asset {
  id               String      @id @default(uuid())
  ipAddress        String? // IPv4 or IPv6
  ipSource         String? // Where ipAddress was last set from: "manual", "fortimanager", "fortigate", etc.
  macAddress       String? // Most recently seen MAC, e.g. "AA:BB:CC:DD:EE:FF"
  hostname         String?
  dnsName          String? // FQDN from PTR lookup, e.g. "server01.corp.local"
  dnsNameFetchedAt DateTime? // When the last PTR lookup ran (success or failure)
  dnsNameTtl       Int? // TTL (seconds) from the PTR record; null = unknown (standard mode)
  assetTag         String?     @unique // Internal tracking tag, e.g. "RGI-00421"
  serialNumber     String?
  manufacturer     String?
  model            String?
  assetType        AssetType   @default(other)
  status           AssetStatus @default(active)
  statusChangedAt  DateTime? // When status was last changed
  statusChangedBy  String? // Who/what changed it: username, integration name, or "system"
  location         String? // User-set location (overrides learnedLocation)
  learnedLocation  String? // Auto-discovered from DHCP (FortiGate name)
  department       String? // Owning department or team
  assignedTo       String? // Person or team responsible
  os               String? // Operating system
  osVersion        String? // OS or firmware version
  lastSeenSwitch   String? // FortiSwitch name/port, e.g. "FS-248E-01/port15"
  lastSeenAp       String? // FortiAP name, e.g. "FAP-431F-01"
  lastSeen         DateTime? // Most recent discovery sighting
  associatedUsers  Json?       @default("[]") // [{user, domain?, lastSeen, source?}] — logged-in / registered users
  latitude         Float? // FortiGate geo coordinate (decimal degrees); populated from `config system global` on discovery
  longitude        Float? // FortiGate geo coordinate (decimal degrees)
  // Raw SNMP sysLocation (OID 1.3.6.1.2.1.1.6.0) pulled during FMG/standalone
  // FortiGate discovery when `fortigateMonitor.pullSnmpLocation` is enabled
  // on the originating integration. Captured independently of whether
  // geocoding produced usable coords — operators see what the FortiGate is
  // telling SNMP even when the geocoder couldn't resolve it. Surfaced on the
  // asset details General tab. The geocoded fallback for `latitude`/`longitude`
  // only runs when the CMDB `gui-device-*` values are missing or malformed
  // (null / NaN / (0,0) / out-of-range) — see syncDhcpSubnets Phase 11.5.
  snmpLocation          String?
  snmpLocationFetchedAt DateTime?
  fortinetTopology Json? // { role: "fortigate" | "fortiswitch" | "fortiap", controllerFortigate?, uplinkInterface?, parentSwitch?, parentPort?, parentVlan? } — real connection graph from FMG/FortiGate discovery
  acquiredAt       DateTime? // Acquisition / purchase date
  warrantyExpiry   DateTime? // Warranty end date
  purchaseOrder    String? // PO or invoice reference
  notes            String?     @db.Text
  tags             String[]    @default([])
  createdBy        String?

  // Stamped during discovery so the Monitoring tab can display the
  // originating integration's name and lock it for FMG/FortiGate-discovered
  // firewalls. Null for manually-created assets.
  discoveredByIntegrationId String?
  discoveredByIntegration   Integration? @relation(fields: [discoveredByIntegrationId], references: [id], onDelete: SetNull)

  // Monitoring. `monitored` toggles whether the monitor job probes this
  // asset. The polling method per stream is resolved through the four-tier
  // hierarchy (per-asset *Polling overrides → MonitorClassOverride →
  // Integration.config.monitorSettings.polling | manualMonitorSettings →
  // source default). `monitorCredentialId` points at a Credential row used
  // by polling methods that need authentication (snmp/winrm/ssh/restapi);
  // FMG/FortiGate-discovered firewalls fall back to the discovering
  // integration's stored API token / SNMP credential when this is null.
  monitored                Boolean     @default(false)
  // Sticky flag set whenever an operator explicitly toggles `monitored` (asset
  // edit modal, bulk-monitor, clickable Status pill in the Assets list). When
  // true, discovery's `addAsMonitored` re-stamp on FortiSwitch/FortiAP/AD paths
  // is suppressed so an operator's manual "unmonitored" choice persists across
  // re-discovery cycles. Cleared only by an operator action — discovery does
  // not flip it.
  monitoredOperatorSet     Boolean     @default(false)
  monitorCredentialId      String?
  monitorCredential        Credential? @relation("AssetMonitorCred", fields: [monitorCredentialId], references: [id], onDelete: SetNull)
  responseTimeCredentialId String?
  responseTimeCredential   Credential? @relation("AssetRTCred", fields: [responseTimeCredentialId], references: [id], onDelete: SetNull)
  cpuMemoryCredentialId    String?
  cpuMemoryCredential      Credential? @relation("AssetCpuMemCred", fields: [cpuMemoryCredentialId], references: [id], onDelete: SetNull)
  temperatureCredentialId  String?
  temperatureCredential    Credential? @relation("AssetTempCred", fields: [temperatureCredentialId], references: [id], onDelete: SetNull)
  interfacesCredentialId   String?
  interfacesCredential     Credential? @relation("AssetInterfacesCred", fields: [interfacesCredentialId], references: [id], onDelete: SetNull)
  lldpCredentialId         String?
  lldpCredential           Credential? @relation("AssetLldpCred", fields: [lldpCredentialId], references: [id], onDelete: SetNull)
  customWidgetCredentialId String?
  customWidgetCredential   Credential? @relation("AssetCustomWidgetCred", fields: [customWidgetCredentialId], references: [id], onDelete: SetNull)
  // Per-stream MIB overrides (String: "std:<key>" or uploaded MIB UUID or null)
  responseTimeMibId        String?
  cpuMemoryMibId           String?
  temperatureMibId         String?
  interfacesMibId          String?
  lldpMibId                String?
  monitorIntervalSec       Int? // Per-asset override for response-time probes; falls back to the resolved tier-3 setting
  // Per-asset override for the probe TCP/UDP/HTTP timeout in milliseconds.
  // Range 100..60000; null = inherit from the resolved tier-3 setting (default 5000ms).
  // Below 500ms the UI shows a warning icon — at that range probes start to
  // false-fail on healthy networks under transient latency.
  probeTimeoutMs           Int?
  // Per-asset override for the CPU+memory collector request timeout (ms).
  // Range 1000..120000; null = inherit. Applied to FortiOS REST + SNMP sessions
  // inside collectCpuMemory.
  cpuMemoryTimeoutMs       Int?
  // Per-asset override for the temperature collector request timeout (ms).
  // Range 1000..120000; null = inherit. Applied to FortiOS REST + SNMP sessions
  // inside collectTemperature (ENTITY-SENSOR-MIB walk + FortiAP scalar
  // fallback).
  temperatureTimeoutMs     Int?
  // Per-asset override for the interface / storage / LLDP collector request
  // timeout (ms). Range 1000..120000; null = inherit. Applied to FortiOS REST +
  // SNMP sessions inside collectSystemInfo + collectFastFiltered.
  systemInfoTimeoutMs      Int?
  // Per-asset override for the custom-widget collector request timeout (ms).
  // Range 1000..120000; null = inherit.
  customWidgetTimeoutMs    Int?
  monitorStatus            String? // "up" | "warning" | "recovering" | "down" | "unknown"
  // Bumped whenever monitorStatus changes value (any transition, not just
  // up<->down). Drives the "how long has this been warning/down" duration on
  // the Dashboard's Monitor Alerts card. Null until the first transition.
  monitorStatusChangedAt   DateTime?
  lastMonitorAt            DateTime?
  lastResponseTimeMs       Int?
  consecutiveFailures      Int         @default(0)
  // Counts probe successes since the last failure. Drives the
  // pending/warning -> up transition: an asset stays in pending or warning
  // until consecutiveSuccesses reaches the resolved failureThreshold (the
  // same value gates both directions). Reset to 0 on any failure.
  consecutiveSuccesses     Int         @default(0)

  // Per-stream polling-method overrides. Each accepts the 5-way enum
  // "rest_api" | "snmp" | "winrm" | "ssh" | "icmp" or null (= inherit from
  // the class override / integration tier / source default). The resolver
  // in monitoringService applies the compatibility matrix from
  // utils/pollingCompatibility — values that don't match the asset's
  // source are silently ignored at resolution time.
  responseTimePolling String?
  cpuMemoryPolling    String?
  temperaturePolling  String?
  interfacesPolling   String?
  lldpPolling         String?
  storagePolling      String?
  // Slice 7 — custom-widget cadence. When the asset's manufacturer has at
  // least one ManufacturerCustomWidget AND this resolves to a non-"disabled"
  // method, collectCustomWidgets fires on the heavy loop. Compatible methods:
  // rest_api | snmp (same set used by telemetry). "disabled" suppresses the
  // probe even when widgets exist for the manufacturer.
  customWidgetPolling String?

  // System tab cadences. CPU/memory and temperature each ride their own
  // cadence — operators can poll CPU/memory every minute via REST while
  // temperature scrapes every five minutes via SNMP, etc. System info = full
  // interface + storage scrape, taken once per ten minutes by default.
  // The per-asset *IntervalSec columns override the global setting when non-null.
  cpuMemoryIntervalSec  Int?
  temperatureIntervalSec Int?
  systemInfoIntervalSec Int?
  // Slice 7 — per-asset custom-widget probe cadence (seconds). null = inherit.
  customWidgetIntervalSec Int?
  lastTelemetryAt       DateTime?
  lastSystemInfoAt      DateTime?
  // Bumped after every successful collectCustomWidgets pass.
  lastCustomWidgetAt    DateTime?

  // ifNames the operator pinned for fast-cadence polling. Each name in this
  // array is also scraped on the response-time interval (default 60s) so that
  // chosen uplinks/critical ports get sub-minute throughput + error history.
  // The full system-info scrape (every ~10 min) still covers all interfaces.
  monitoredInterfaces String[] @default([])

  // Storage mountPaths pinned for fast-cadence polling. Same model as
  // monitoredInterfaces — the response-time tick re-walks just these
  // hrStorage rows so the operator gets sub-minute disk-usage history for
  // chosen volumes without re-walking the full storage table.
  monitoredStorage String[] @default([])

  // Phase-1 tunnel names pinned for fast-cadence IPsec polling. The full
  // /api/v2/monitor/vpn/ipsec endpoint can be slow on busy gateways so it
  // is not re-walked every minute by default; pinning a tunnel here issues
  // a targeted scrape that filters down to just that phase-1.
  monitoredIpsecTunnels String[] @default([])

  // Quarantine. When non-null the asset is currently quarantined on one or
  // more FortiGates (per quarantineTargets). statusBeforeQuarantine stores
  // the prior AssetStatus so release can pop it back; null pops to active.
  // quarantinedBy records the actor that initiated: "user:<username>" for a
  // session-auth caller, "api:<token-name>" for an API-token caller, or
  // "system:auto-quarantine" when the discovery sync auto-extends an existing
  // quarantine to a newly-sighted FortiGate.
  // quarantineTargets is a JSON array of per-FortiGate push records:
  //   [{ fortigateDevice, integrationId, pushedMacs: string[], pushedAt,
  //      status: "synced"|"failed"|"drift", error? }]
  // The asset's status is set to AssetStatus.quarantined on any successful
  // push (partial-across-fortigates is allowed; per-FortiGate is all-or-
  // nothing). Release best-efforts an unpush from each target before flipping
  // status back; per-target failure does not block the release.
  statusBeforeQuarantine AssetStatus?
  quarantineReason       String?      @db.Text
  quarantinedAt          DateTime?
  quarantinedBy          String?
  quarantineTargets      Json         @default("[]")

  // Dependency-aware monitoring suppression. dependencyLayer is the BFS
  // shortest-path distance from any FortiGate root (1 = FortiGate, 2 =
  // direct child switch/AP, 3+ = chained). dependencySuppressed is the
  // runtime flag set by the dependencyReconciler job when ALL of the
  // asset's effective parents are confirmed down (or themselves
  // suppressed). While suppressed, telemetry / systemInfo / fastFiltered
  // are skipped and the response-time probe runs at 2× the resolved
  // interval. See dependencyTreeService for the resolution rules.
  dependencyLayer        Int?
  dependencySuppressed   Boolean   @default(false)
  dependencySuppressedAt DateTime?

  // Admin-only "Dependency Test" simulation. When dependencyTestUntil is in
  // the future, the dependency reconciler treats THIS asset as if it were
  // confirmed down for the purposes of suppression — so children with this
  // asset in their effective parent set get marked dependencySuppressed
  // exactly as they would under a real outage. Real probes keep running and
  // updating monitorStatus / lastResponseTimeMs normally; the test is a
  // pure overlay that ends automatically at the timestamp. The reconciler
  // also auto-clears expired rows (sets dependencyTestUntil back to null).
  // Only admins can set or clear this — assets-admin and network-admin do
  // not have the privilege. See routes/assets.ts ":id/dependency-test".
  dependencyTestUntil     DateTime?
  dependencyTestStartedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conflicts           Conflict[]
  ipHistory           AssetIpHistory[]
  fortigateSightings  AssetFortigateSighting[]
  monitorSamples      AssetMonitorSample[]
  telemetrySamples    AssetTelemetrySample[]
  interfaceSamples    AssetInterfaceSample[]
  interfaceOverrides  AssetInterfaceOverride[]
  storageSamples      AssetStorageSample[]
  temperatureSamples  AssetTemperatureSample[]
  ipsecTunnelSamples  AssetIpsecTunnelSample[]
  // Tiered sample rollups (hourly + daily aggregates). Populated by the
  // sampleRollup job from the source tables above. Cascade-delete with the
  // asset so a removed device's history vanishes from every tier at once.
  monitorSamplesHourly     AssetMonitorSampleHourly[]
  monitorSamplesDaily      AssetMonitorSampleDaily[]
  telemetrySamplesHourly   AssetTelemetrySampleHourly[]
  telemetrySamplesDaily    AssetTelemetrySampleDaily[]
  temperatureSamplesHourly AssetTemperatureSampleHourly[]
  temperatureSamplesDaily  AssetTemperatureSampleDaily[]
  interfaceSamplesHourly   AssetInterfaceSampleHourly[]
  interfaceSamplesDaily    AssetInterfaceSampleDaily[]
  storageSamplesHourly     AssetStorageSampleHourly[]
  storageSamplesDaily      AssetStorageSampleDaily[]
  ipsecTunnelSamplesHourly AssetIpsecTunnelSampleHourly[]
  ipsecTunnelSamplesDaily  AssetIpsecTunnelSampleDaily[]
  lldpNeighbors       AssetLldpNeighbor[]      @relation("AssetLldpNeighbors")
  lldpNeighborMatches AssetLldpNeighbor[]      @relation("AssetLldpNeighborMatch")
  // Wireless stations connected to this asset (when it's a FortiAP) and
  // back-link for endpoints matched to a station's MAC via the SNMP
  // fapStationTable scrape.
  wirelessStations         AssetWirelessStation[] @relation("AssetWirelessStationsOnAp")
  wirelessStationMatches   AssetWirelessStation[] @relation("AssetWirelessStationMatch")
  mibFiles                 MibFile[]              @relation("MibFilesOnAsset")
  customWidgetSamples      AssetCustomWidgetSample[] @relation("AssetCustomWidgetSamples")
  sources             AssetSource[]
  associatedIpRows    AssetAssociatedIp[]
  macAddressRows      AssetMacAddress[]
  dependencyParents   AssetDependencyParent[]  @relation("AssetDependencyChild")
  dependencyChildren  AssetDependencyParent[]  @relation("AssetDependencyParent")
  managedAgent        ManagedAgent?

  @@index([ipAddress])
  @@index([macAddress])
  @@index([hostname])
  @@index([assetType])
  @@index([status])
  @@index([department])
  @@index([serialNumber])
  @@index([dnsName])
  @@index([createdBy])
  @@index([discoveredByIntegrationId])
  @@index([monitored])
  @@index([monitored, lastMonitorAt])
  @@index([dependencySuppressed])
  @@map("assets")
}

// Rolling time-series of monitoring probe results. One row per probe;
// `responseTimeMs` is null on failure (used as the "packet loss" signal).
model AssetMonitorSample {
  id             String   @default(uuid())
  assetId        String
  asset          Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp      DateTime @default(now())
  success        Boolean
  responseTimeMs Int?
  error          String?  @db.Text

  // Composite PK (id, timestamp) — required by TimescaleDB hypertables to
  // include the partitioning column. Works fine on plain Postgres too;
  // queries don't change.
  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@map("asset_monitor_samples")
}

// CPU and memory snapshot, written once per `monitor.telemetryIntervalSeconds`
// by the System tab cadence in monitorAssets. Only populated when the asset's
// monitor type can deliver these (FortiOS/SNMP/WinRM); ICMP/SSH yield nothing.
// `cpuPct` is a 0-100 percentage; memory is bytes (BigInt to avoid overflow on
// large servers).
model AssetTelemetrySample {
  id            String   @default(uuid())
  assetId       String
  asset         Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp     DateTime @default(now())
  cpuPct        Float?
  // memPct is populated when the source reports memory only as a percentage
  // (FortiOS); memUsedBytes / memTotalBytes are populated when the source
  // reports absolute bytes (SNMP HOST-RESOURCES-MIB, WMI). Either pair may
  // be present — the UI prefers bytes when both are available.
  memPct        Float?
  memUsedBytes  BigInt?
  memTotalBytes BigInt?

  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@map("asset_telemetry_samples")
}

// Per-interface snapshot, written once per `monitor.systemInfoIntervalSeconds`.
// Many rows per scrape — one per interface returned by the device. inOctets /
// outOctets are cumulative SNMP/FortiOS counters; subtracting consecutive
// samples gives throughput for charting.
model AssetInterfaceSample {
  id          String   @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp   DateTime @default(now())
  ifName      String
  adminStatus String?
  operStatus  String?
  speedBps    BigInt?
  ipAddress   String?
  macAddress  String?
  inOctets    BigInt?
  outOctets   BigInt?
  // Cumulative error counters (IF-MIB ifInErrors / ifOutErrors, FortiOS
  // errors_in / errors_out). Subtract consecutive samples for an error rate.
  inErrors    BigInt?
  outErrors   BigInt?
  // Interface topology — populated by FortiOS REST path; SNMP sets ifType only.
  // ifType: "physical" | "aggregate" | "vlan" | "loopback" | "tunnel"
  // ifParent: aggregate name for member ports; parent interface name for VLANs
  // vlanId: 802.1Q VLAN ID for vlan-type interfaces
  ifType      String?
  ifParent    String?
  vlanId      Int?
  // Operator-set label that overrides ifName in the UI when present.
  // FortiOS CMDB `alias`; SNMP IF-MIB ifAlias (1.3.6.1.2.1.31.1.1.1.18).
  alias       String?
  // Operator-set free-text comment surfaced on the interface slide-over.
  // FortiOS CMDB `description`; SNMP has no equivalent and leaves this null.
  description String?

  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@index([assetId, ifName, timestamp])
  @@map("asset_interface_samples")
}

// Per-asset additional IPs ("interface IPs", "secondary IPs", manually-tagged
// IPs). Replaces the legacy `Asset.associatedIps` JSONB column. Populated by:
//   - System-info scrape (one row per interface that returned an IP, with
//     source="monitor-system-info"). Reconciled per scrape: rows owned by
//     a non-manual source are deleted in bulk and re-inserted with the
//     fresh interface set, while source="manual" rows are preserved.
//   - Manual edits via assets.ts (PATCH /assets/:id payload still carries
//     `associatedIps` as a JSON array; the route serializes both directions).
//   - Discovery currently does NOT write this table directly — it relies on
//     the live monitor pull as the single source per the original design.
//
// Read paths: bulk DNS PTR refresh, single-asset DNS lookup, the LLDP
// neighbor match index, and the assets list/get response (which serializes
// rows back into the `associatedIps` JSON shape so the frontend reads the
// same field name as before).
model AssetAssociatedIp {
  id            String    @id @default(uuid())
  assetId       String
  asset         Asset     @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ip            String
  // Free-text source identifier. Stable values used by the codebase:
  //   "manual"                — operator-added via the assets edit panel
  //   "monitor-system-info"   — written by the systemInfo scrape
  //   plus various legacy values from older discovery paths preserved
  //   from the JSON backfill (the column is text not enum to match the
  //   prior open shape).
  source        String
  interfaceName String?
  // Per-IP MAC. May differ from `Asset.macAddress` (which is the asset's
  // primary MAC) — many devices have one MAC per interface.
  mac           String?
  // PTR cache. ptrFetchedAt is the wall-clock of the last reverse-DNS
  // attempt (success or failure); ptrTtl is the TTL the resolver returned
  // when there was a hit. Used by the bulk DNS job to decide which entries
  // are due for re-resolution.
  ptrName       String?
  ptrTtl        Int?
  ptrFetchedAt  DateTime?
  lastSeen      DateTime  @default(now())
  firstSeen     DateTime  @default(now())

  @@unique([assetId, ip])
  @@index([assetId])
  @@index([ip])
  @@map("asset_associated_ips")
}

// All MAC addresses an asset has been seen with. Replaces the legacy
// `Asset.macAddresses` JSONB column. Populated by:
//   - DHCP discovery (FMG / FortiGate, source="fmg-discovery" or "fortigate")
//   - Device-inventory FortiOS sweep (source="device-inventory")
//   - Intune sync (source="intune-ethernet" / "intune-wifi")
//   - AD computer-object sync (source="ad")
//   - Conflict ghost-merge (preserved from the deleted ghost asset)
//   - Manual edits via the asset edit panel (source="manual")
//
// `Asset.macAddress` (the scalar column on Asset) remains the asset's
// primary MAC — typically the most recently-seen entry. The relation
// here is the FULL history; quarantine push, LLDP matching, and the
// `mac-collision` conflict pathway all walk this table to find every MAC
// the asset has ever advertised.
//
// Persist semantics: discovery code that builds an in-memory mac list
// (deduped by normalized MAC, sorted by lastSeen desc) calls
// `reconcileMacAddresses(assetId, macs)` from src/utils/macAddresses.ts to
// sync the side table after the asset.update lands. The list/get response
// serializes the relation back into the legacy `macAddresses: [...]` JSON
// shape so existing API consumers (the frontend, external integrations)
// keep reading the same field name.
model AssetMacAddress {
  id         String   @id @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  // Normalized to colon-uppercase form (AA:BB:CC:DD:EE:FF) at write time.
  // Frontends that present MACs format from this canonical form.
  mac        String
  source     String
  // Optional metadata that some sources include. `device` is the FortiGate
  // hostname when this MAC came from a DHCP scrape; `subnetCidr` /
  // `subnetName` are populated when the MAC's IP at sighting time fell
  // inside a known Polaris subnet on that FortiGate.
  device     String?
  subnetCidr String?
  subnetName String?
  lastSeen   DateTime @default(now())
  firstSeen  DateTime @default(now())

  @@unique([assetId, mac])
  @@index([assetId])
  @@index([mac])
  @@map("asset_mac_addresses")
}

// Operator-typed override for an interface's "Interface Comments" text box.
// Takes priority over the discovered AssetInterfaceSample.description (FortiOS
// CMDB `description`) for display only — Polaris never pushes this back to the
// device. One row per (assetId, ifName); a null/empty `description` clears the
// override and the discovered comment shows through again.
model AssetInterfaceOverride {
  id          String   @id @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  ifName      String
  description String?  @db.VarChar(255)
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([assetId, ifName])
  @@index([assetId])
  @@map("asset_interface_overrides")
}

// Per-sensor temperature snapshot, written alongside telemetry. FortiOS exposes
// these via /api/v2/monitor/system/sensor-info (filtered to type "temperature").
// SNMP via ENTITY-SENSOR-MIB (entPhySensorType=8/celsius). Hosts that don't
// publish either get no rows; the System tab simply hides the section.
model AssetTemperatureSample {
  id         String   @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())
  sensorName String
  celsius    Float?

  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@index([assetId, sensorName, timestamp])
  @@map("asset_temperature_samples")
}

// Per-tunnel IPsec snapshot, written on the system-info cadence. FortiOS only
// (read from /api/v2/monitor/vpn/ipsec). One row per phase-1 tunnel; status
// rolls phase-2 selectors up to "up" / "down" / "partial". Bytes are
// cumulative — subtracting consecutive samples gives tunnel throughput.
model AssetIpsecTunnelSample {
  id              String   @default(uuid())
  assetId         String
  asset           Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp       DateTime @default(now())
  tunnelName      String
  // Parent interface from `config vpn ipsec phase1-interface` (the FortiOS
  // CMDB `interface` field — typically the WAN port the tunnel rides, e.g.
  // "wan1" or a VLAN sub-interface). The System tab uses this to nest tunnel
  // rows under their parent in the Interfaces table. Null when the CMDB
  // endpoint is unreachable or returns no matching phase-1.
  parentInterface String?
  remoteGateway   String?
  // "up" = every phase-2 selector is up; "down" = every selector down; "partial" = mix.
  status          String
  // Sum of incoming/outgoing bytes across every phase-2 selector under this
  // phase-1. FortiOS resets the counter when phase-1 renegotiates, so the UI
  // must treat decreases as a counter reset rather than negative throughput.
  incomingBytes   BigInt?
  outgoingBytes   BigInt?
  proxyIdCount    Int?

  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@index([assetId, tunnelName, timestamp])
  @@map("asset_ipsec_tunnel_samples")
}

// LLDP neighbor table — current-state per (asset, local interface). Replaced
// in full on every system-info pass that successfully queried LLDP (FortiOS
// /api/v2/monitor/system/interface/lldp-neighbors, or SNMP LLDP-MIB::lldpRemTable).
// `firstSeen` tracks the original sighting across persists so the System tab
// can show "first seen N days ago"; `lastSeen` is bumped on every refresh.
//
// `matchedAssetId` is filled in at persist time when the neighbor's chassis
// MAC, management IP, or system name resolves to another Polaris Asset — that
// powers the Device Map topology graph (LLDP gives us real edges to non-
// Fortinet gear that fortinetTopology can't see). The relation uses SetNull
// so deleting the matched asset doesn't cascade-delete the neighbor row, just
// clears the back-pointer.
//
// `source` is "fortios" (FortiOS REST collector) or "snmp" (LLDP-MIB walk),
// kept around mostly for diagnostics — both transports normalize into the
// same row shape before insert.
model AssetLldpNeighbor {
  id          String @id @default(uuid())
  assetId     String
  asset       Asset  @relation("AssetLldpNeighbors", fields: [assetId], references: [id], onDelete: Cascade)
  localIfName String

  chassisIdSubtype  String?
  chassisId         String?
  portIdSubtype     String?
  portId            String?
  portDescription   String?
  systemName        String?
  systemDescription String?  @db.Text
  managementIp      String?
  capabilities      String[] @default([])

  matchedAssetId String?
  matchedAsset   Asset?  @relation("AssetLldpNeighborMatch", fields: [matchedAssetId], references: [id], onDelete: SetNull)

  source String // "fortios" | "snmp"

  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())

  @@unique([assetId, localIfName, chassisId, portId])
  @@index([assetId])
  @@index([assetId, localIfName])
  @@index([matchedAssetId])
  @@map("asset_lldp_neighbors")
}

// Wireless stations connected to a FortiAP. Populated from SNMP
// `fapStationTable` (1.3.6.1.4.1.12356.120.8.1.1) by the system-info pass
// on `assetType="access_point"` assets monitored via SNMP. Mirrors the
// AssetLldpNeighbor shape but **without** the 48h stickiness window —
// wireless clients are transient by design; a station absent from a fresh
// scrape means the client roamed or disconnected, drop it immediately.
//
// `matchedAssetId` is resolved at persist time via a MAC-match against
// the endpoint inventory (same logic as LLDP). When set, the endpoint
// owning that MAC gets its `Asset.lastSeenAp` stamped to the AP's
// hostname so the asset details view shows which AP last saw the
// device.
model AssetWirelessStation {
  id             String @id @default(uuid())
  apAssetId      String
  apAsset        Asset  @relation("AssetWirelessStationsOnAp", fields: [apAssetId], references: [id], onDelete: Cascade)
  staMacAddr     String  // normalized colon-uppercase (AA:BB:CC:DD:EE:FF)

  staIpAddr      String?
  ssid           String?
  radioId        Int?
  wlanId         Int?
  vlanId         Int?
  bssid          String?
  signalStrength Int?    // dBm
  noise          Int?    // dBm
  bandwidthTx    Int?    // kbps
  bandwidthRx    Int?    // kbps
  idleSeconds    Int?

  matchedAssetId String?
  matchedAsset   Asset?  @relation("AssetWirelessStationMatch", fields: [matchedAssetId], references: [id], onDelete: SetNull)

  source         String  // "snmp" (FortiOS REST path lands in a follow-up commit)

  firstSeen      DateTime @default(now())
  lastSeen       DateTime @default(now())

  @@unique([apAssetId, staMacAddr])
  @@index([apAssetId])
  @@index([matchedAssetId])
  @@index([staMacAddr])
  @@map("asset_wireless_stations")
}

// Slice 7 — time-series of custom-widget samples. Each row is one
// ManufacturerCustomWidget probe result against one asset. `kind` is
// "scalar" or "table" (mirrors the widget definition); `value` holds either
// a single number (scalar) or an array of row objects (table). Pruned on
// the system-info retention cadence — same retention knob as interfaces
// since both ride the heavy loop.
model AssetCustomWidgetSample {
  id        String   @id @default(uuid())
  assetId   String
  asset     Asset    @relation("AssetCustomWidgetSamples", fields: [assetId], references: [id], onDelete: Cascade)
  widgetId  String   // stable UUID from ManufacturerCustomWidget; NOT an FK so
                     // a widget delete doesn't cascade-blow historical samples
                     // (the Custom MIB tab still shows the last-known values
                     // until retention prunes them out).
  timestamp DateTime @default(now())
  kind      String   // "scalar" | "table"
  value     Json     // number for scalar; row array for table

  @@index([assetId, timestamp])
  @@index([assetId, widgetId, timestamp])
  @@index([widgetId])
  @@map("asset_custom_widget_samples")
}

// Per-mountpoint storage snapshot, written alongside interface samples.
model AssetStorageSample {
  id         String   @default(uuid())
  assetId    String
  asset      Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  timestamp  DateTime @default(now())
  mountPath  String
  totalBytes BigInt?
  usedBytes  BigInt?

  @@id([id, timestamp])
  @@index([assetId, timestamp])
  @@index([assetId, mountPath, timestamp])
  @@map("asset_storage_samples")
}

// ─── Sample rollups (tiered retention: hourly + daily aggregates) ───────────
//
// Per-source aggregate tables populated by the sampleRollup job (custom
// INSERT...ON CONFLICT). On Timescale-installed instances these become
// hypertables with the same compression policy as the source tables; on
// plain Postgres they stay as regular tables. The schema is uniform across
// both — see the plan at ~/.claude/plans/changed-to-plan-mode-velvet-elephant.md.
//
// Common conventions:
//   - Composite PK (id, bucketStart): id is a synthetic UUID for row identity;
//     bucketStart is the Timescale partitioning column.
//   - Composite UNIQUE on (bucketStart, assetId, [extraKey]): enforces one row
//     per asset (and extraKey when present) per time bucket, so the rollup
//     job's INSERT...ON CONFLICT (bucketStart, assetId[, extraKey]) DO UPDATE
//     works without duplicates.
//   - bucketStart timestamps are always UTC, aligned to the bucket boundary
//     via time_bucket('1 hour', timestamp) / time_bucket('1 day', ...).
//   - Gauge tables carry avg/min/max + sampleCount.
//   - Counter tables carry first/last endpoints of each cumulative counter
//     plus lastBucketSampleAt; rate is derived at query time as
//     (last - first) / (lastBucketSampleAt - bucketStart in seconds).
//     Negative deltas are dropped as counter resets (same convention as
//     the detail-tier client-side rate calc in the chart renderers).
//
// Phase 1 only — these tables exist but no reader or writer consumes them
// yet. The rollup job + tier-routing helper land in phases 2 and 4.

model AssetMonitorSampleHourly {
  id                String   @default(uuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart       DateTime
  sampleCount       Int
  successCount      Int
  failureCount      Int
  // avgResponseTimeMs is computed over successful samples only; null when
  // the bucket had zero successes. min/max likewise restricted to successes.
  avgResponseTimeMs Float?
  minResponseTimeMs Int?
  maxResponseTimeMs Int?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId])
  @@index([assetId, bucketStart])
  @@map("asset_monitor_samples_hourly")
}

model AssetMonitorSampleDaily {
  id                String   @default(uuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart       DateTime
  sampleCount       Int
  successCount      Int
  failureCount      Int
  avgResponseTimeMs Float?
  minResponseTimeMs Int?
  maxResponseTimeMs Int?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId])
  @@index([assetId, bucketStart])
  @@map("asset_monitor_samples_daily")
}

model AssetTelemetrySampleHourly {
  id                String   @default(uuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart       DateTime
  sampleCount       Int
  avgCpuPct         Float?
  minCpuPct         Float?
  maxCpuPct         Float?
  avgMemPct         Float?
  minMemPct         Float?
  maxMemPct         Float?
  avgMemUsedBytes   BigInt?
  maxMemUsedBytes   BigInt?
  // last-seen total (memory size is effectively a constant per host;
  // tracking last value rather than avg keeps the chart axis stable).
  lastMemTotalBytes BigInt?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId])
  @@index([assetId, bucketStart])
  @@map("asset_telemetry_samples_hourly")
}

model AssetTelemetrySampleDaily {
  id                String   @default(uuid())
  assetId           String
  asset             Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart       DateTime
  sampleCount       Int
  avgCpuPct         Float?
  minCpuPct         Float?
  maxCpuPct         Float?
  avgMemPct         Float?
  minMemPct         Float?
  maxMemPct         Float?
  avgMemUsedBytes   BigInt?
  maxMemUsedBytes   BigInt?
  lastMemTotalBytes BigInt?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId])
  @@index([assetId, bucketStart])
  @@map("asset_telemetry_samples_daily")
}

model AssetTemperatureSampleHourly {
  id          String   @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart DateTime
  sensorName  String
  sampleCount Int
  avgCelsius  Float?
  minCelsius  Float?
  maxCelsius  Float?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId, sensorName])
  @@index([assetId, bucketStart])
  @@index([assetId, sensorName, bucketStart])
  @@map("asset_temperature_samples_hourly")
}

model AssetTemperatureSampleDaily {
  id          String   @default(uuid())
  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart DateTime
  sensorName  String
  sampleCount Int
  avgCelsius  Float?
  minCelsius  Float?
  maxCelsius  Float?

  @@id([id, bucketStart])
  @@unique([bucketStart, assetId, sensorName])
  @@index([assetId, bucketStart])
  @@index([assetId, sensorName, bucketStart])
  @@map("asset_temperature_samples_daily")
}

model AssetInterfaceSampleHourly {
  id                  String   @default(uuid())
  assetId             String
  asset               Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)
  bucketStart         DateTime
  ifName              String
  sampleCount         Int
  // Counter endpoints — rate computed at query time as
  // (last - first) / (lastBucketSampleAt - bucketStart in seconds).
  // Negative results dropped as counter resets.
  firstInOctets       BigInt?
  lastInOctets        BigInt?
  firstOutOctets      BigInt?
  lastOutOctets       BigInt?
  firstInErrors       BigInt?
