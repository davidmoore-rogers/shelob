// Prisma Schema — IP Address Management (IPAM)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum IpVersion {
  v4
  v6
}

enum SubnetStatus {
  available
  reserved
  deprecated
}

enum ReservationStatus {
  active
  expired
  released
}

enum UserRole {
  admin
  user
}

// ─── Models ───────────────────────────────────────────────────────────────────

model IpBlock {
  id          String    @id @default(uuid())
  name        String
  cidr        String    @unique
  ipVersion   IpVersion
  description String?   @db.Text
  tags        String[]  @default([])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subnets     Subnet[]

  @@index([ipVersion])
  @@map("ip_blocks")
}

model Subnet {
  id          String       @id @default(uuid())
  blockId     String
  block       IpBlock      @relation(fields: [blockId], references: [id], onDelete: Cascade)

  cidr        String       @unique
  name        String
  purpose     String?      @db.Text
  status      SubnetStatus @default(available)
  vlan        Int?
  tags        String[]     @default([])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reservations Reservation[]

  @@index([blockId])
  @@index([status])
  @@map("subnets")
}

model Reservation {
  id         String            @id @default(uuid())
  subnetId   String
  subnet     Subnet            @relation(fields: [subnetId], references: [id], onDelete: Cascade)

  ipAddress  String?
  hostname   String?
  owner      String
  projectRef String
  expiresAt  DateTime?
  notes      String?           @db.Text
  status     ReservationStatus @default(active)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([subnetId, ipAddress, status])
  @@index([subnetId])
  @@index([owner])
  @@index([projectRef])
  @@index([status])
  @@index([expiresAt])
  @@map("reservations")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(user)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
