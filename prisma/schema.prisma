// Prisma Schema — Shelob (Subnet & IP Address Management)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum IpVersion {
  v4
  v6
}

enum SubnetStatus {
  available
  reserved
  deprecated
}

enum ReservationStatus {
  active
  expired
  released
}

enum UserRole {
  admin
  networkadmin
  assetsadmin
  user
  readonly
}

// ─── Models ───────────────────────────────────────────────────────────────────

model IpBlock {
  id          String    @id @default(uuid())
  name        String
  cidr        String    @unique
  ipVersion   IpVersion
  description String?   @db.Text
  tags        String[]  @default([])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subnets     Subnet[]

  @@index([ipVersion])
  @@map("ip_blocks")
}

model Subnet {
  id              String       @id @default(uuid())
  blockId         String
  block           IpBlock      @relation(fields: [blockId], references: [id], onDelete: Cascade)

  cidr            String
  name            String
  purpose         String?      @db.Text
  status          SubnetStatus @default(available)
  vlan            Int?
  tags            String[]     @default([])

  discoveredBy    String?
  integration     Integration? @relation(fields: [discoveredBy], references: [id], onDelete: SetNull)
  fortigateDevice String?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  reservations    Reservation[]

  @@index([blockId])
  @@index([blockId, status])
  @@index([cidr])
  @@index([status])
  @@index([discoveredBy])
  @@map("subnets")
}

model Reservation {
  id         String            @id @default(uuid())
  subnetId   String
  subnet     Subnet            @relation(fields: [subnetId], references: [id], onDelete: Cascade)

  ipAddress  String?
  hostname   String?
  owner      String?
  projectRef String?
  expiresAt  DateTime?
  notes      String?           @db.Text
  status     ReservationStatus @default(active)
  createdBy  String?                              // Username of the user who created this reservation
  conflictMessage String?                         // Set by discovery when DHCP data conflicts with this reservation

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([subnetId, ipAddress, status])
  @@index([subnetId])
  @@index([subnetId, status])
  @@index([owner])
  @@index([projectRef])
  @@index([status])
  @@index([status, expiresAt])
  @@index([expiresAt])
  @@index([createdBy])
  @@map("reservations")
}

model Integration {
  id        String   @id @default(uuid())
  type      String                         // e.g. "fortimanager"
  name      String                         // Human-readable label
  config    Json     @default("{}")         // Connection settings (host, port, adom, etc.)
  enabled       Boolean  @default(true)
  autoDiscover  Boolean  @default(true)
  pollInterval  Int      @default(4)    // Auto-discovery interval in hours (1–24)
  lastTestAt    DateTime?
  lastTestOk    Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subnets   Subnet[]

  @@index([type])
  @@index([enabled])
  @@map("integrations")
}

model Event {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  level        String   @default("info")        // info, warning, error
  action       String                            // e.g. "block.created", "integration.discover.started"
  resourceType String?                           // e.g. "block", "subnet", "integration"
  resourceId   String?
  resourceName String?
  actor        String?                           // username that triggered the event
  message      String   @db.Text
  details      Json?                             // Optional extra context (error stack, diff, etc.)

  @@index([timestamp])
  @@index([action])
  @@index([resourceType])
  @@index([level])
  @@map("events")
}

enum AssetStatus {
  active
  maintenance
  decommissioned
  storage
}

enum AssetType {
  server
  switch
  router
  firewall
  workstation
  printer
  access_point
  other
}

model Asset {
  id             String      @id @default(uuid())
  ipAddress      String?                           // IPv4 or IPv6
  macAddress     String?                           // Most recently seen MAC, e.g. "AA:BB:CC:DD:EE:FF"
  macAddresses   Json?       @default("[]")       // [{mac, lastSeen, source?}] — all associated MACs
  hostname       String?
  dnsName        String?                           // FQDN, e.g. "server01.corp.local"
  assetTag       String?     @unique               // Internal tracking tag, e.g. "RGI-00421"
  serialNumber   String?
  manufacturer   String?
  model          String?
  assetType      AssetType   @default(other)
  status         AssetStatus @default(active)
  location       String?                           // User-set location (overrides learnedLocation)
  learnedLocation String?                          // Auto-discovered from DHCP (FortiGate name)
  department     String?                           // Owning department or team
  assignedTo     String?                           // Person or team responsible
  os             String?                           // Operating system
  osVersion      String?                           // OS or firmware version
  lastSeenSwitch String?                           // FortiSwitch name/port, e.g. "FS-248E-01/port15"
  lastSeenAp     String?                           // FortiAP name, e.g. "FAP-431F-01"
  associatedUsers Json?     @default("[]")        // [{user, domain?, lastSeen, source?}] — logged-in / registered users
  acquiredAt     DateTime?                         // Acquisition / purchase date
  warrantyExpiry DateTime?                         // Warranty end date
  purchaseOrder  String?                           // PO or invoice reference
  notes          String?     @db.Text
  tags           String[]    @default([])

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([ipAddress])
  @@index([macAddress])
  @@index([hostname])
  @@index([assetType])
  @@index([status])
  @@index([department])
  @@index([serialNumber])
  @@index([dnsName])
  @@map("assets")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(readonly)
  authProvider String   @default("local") @map("auth_provider")  // "local" or "azure"
  azureOid     String?  @unique @map("azure_oid")                // Azure AD Object ID
  displayName  String?  @map("display_name")
  email        String?
  lastLogin    DateTime? @map("last_login")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

model Setting {
  key       String   @id
  value     Json     @default("{}")
  updatedAt DateTime @updatedAt

  @@map("settings")
}

model Tag {
  id        String   @id @default(uuid())
  name      String   @unique
  category  String   @default("General")
  color     String   @default("#4fc3f7")

  createdAt DateTime @default(now())

  @@index([category])
  @@map("tags")
}
