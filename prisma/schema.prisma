// Prisma Schema — Shelob (Subnet & IP Address Management)
// Run: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum IpVersion {
  v4
  v6
}

enum SubnetStatus {
  available
  reserved
  deprecated
}

enum ReservationStatus {
  active
  expired
  released
}

enum UserRole {
  admin
  user
}

// ─── Models ───────────────────────────────────────────────────────────────────

model IpBlock {
  id          String    @id @default(uuid())
  name        String
  cidr        String    @unique
  ipVersion   IpVersion
  description String?   @db.Text
  tags        String[]  @default([])

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  subnets     Subnet[]

  @@index([ipVersion])
  @@map("ip_blocks")
}

model Subnet {
  id          String       @id @default(uuid())
  blockId     String
  block       IpBlock      @relation(fields: [blockId], references: [id], onDelete: Cascade)

  cidr        String       @unique
  name        String
  purpose     String?      @db.Text
  status      SubnetStatus @default(available)
  vlan        Int?
  tags        String[]     @default([])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  reservations Reservation[]

  @@index([blockId])
  @@index([status])
  @@map("subnets")
}

model Reservation {
  id         String            @id @default(uuid())
  subnetId   String
  subnet     Subnet            @relation(fields: [subnetId], references: [id], onDelete: Cascade)

  ipAddress  String?
  hostname   String?
  owner      String
  projectRef String
  expiresAt  DateTime?
  notes      String?           @db.Text
  status     ReservationStatus @default(active)

  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@unique([subnetId, ipAddress, status])
  @@index([subnetId])
  @@index([owner])
  @@index([projectRef])
  @@index([status])
  @@index([expiresAt])
  @@map("reservations")
}

model Integration {
  id        String   @id @default(uuid())
  type      String                         // e.g. "fortimanager"
  name      String                         // Human-readable label
  config    Json     @default("{}")         // Connection settings (host, port, adom, etc.)
  enabled   Boolean  @default(true)
  lastTestAt  DateTime?
  lastTestOk  Boolean?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("integrations")
}

enum AssetStatus {
  active
  maintenance
  decommissioned
  storage
}

enum AssetType {
  server
  switch
  router
  firewall
  workstation
  printer
  access_point
  other
}

model Asset {
  id             String      @id @default(uuid())
  ipAddress      String?                           // IPv4 or IPv6
  macAddress     String?                           // e.g. "AA:BB:CC:DD:EE:FF"
  hostname       String?
  dnsName        String?                           // FQDN, e.g. "server01.corp.local"
  assetTag       String?     @unique               // Internal tracking tag, e.g. "RGI-00421"
  serialNumber   String?
  manufacturer   String?
  model          String?
  assetType      AssetType   @default(other)
  status         AssetStatus @default(active)
  location       String?                           // Building, rack, room
  department     String?                           // Owning department or team
  assignedTo     String?                           // Person or team responsible
  os             String?                           // Operating system
  acquiredAt     DateTime?                         // Acquisition / purchase date
  warrantyExpiry DateTime?                         // Warranty end date
  purchaseOrder  String?                           // PO or invoice reference
  notes          String?     @db.Text
  tags           String[]    @default([])

  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([ipAddress])
  @@index([macAddress])
  @@index([hostname])
  @@index([assetType])
  @@index([status])
  @@index([department])
  @@map("assets")
}

model User {
  id           String   @id @default(uuid())
  username     String   @unique
  passwordHash String   @map("password_hash")
  role         UserRole @default(user)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}
