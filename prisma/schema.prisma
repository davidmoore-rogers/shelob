model User {
  id           String    @id @default(uuid())
  username     String    @unique
  passwordHash String    @map("password_hash")
  roleId       String    @map("role_id")
  role         Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  // Per-user region scope. Empty = unrestricted (matches pre-cutover default
  // so existing accounts aren't suddenly locked out). Effective regions for
  // a session are `union(role.regionTags, user.regionTags)`. Storage only —
  // the consumer (asset / subnet / reservation list filters; map view) lives
  // in a separate change.
  regionTags   String[]  @default([]) @map("region_tags")
  authProvider String    @default("local") @map("auth_provider") // "local" or "azure"
  azureOid     String?   @unique @map("azure_oid") // Azure AD Object ID
  displayName  String?   @map("display_name")
  email        String?
  lastLogin    DateTime? @map("last_login")

  // TOTP (second-factor) — local accounts only. An enrollment is in progress
  // when totpSecret is set but totpEnabledAt is null; verification of the
  // first 6-digit code finalizes it. Backup codes are stored as argon2id
  // hashes so they're verified the same way passwords are.
  totpSecret      String?   @map("totp_secret")
  totpEnabledAt   DateTime? @map("totp_enabled_at")
  totpBackupCodes String[]  @default([]) @map("totp_backup_codes")

  // Flipped true the first time the user actually logs in (lastLogin transitions
  // null → set). Drives the sidebar "new user — review role" notification for
  // admins; cleared globally by Dismiss.
  needsRoleReview Boolean   @default(false) @map("needs_role_review")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  dashboard UserDashboard?

  @@index([roleId])
  @@map("users")
}

// Per-user dashboard layout. One row per user; absent row = "empty
// dashboard" (Use the + Widget button to get started). `layout` is the
// JSON blob shape `{ version: 1, widgets: WidgetInstance[] }` validated
// at the route layer by Zod — see src/api/routes/userDashboard.ts.
// Persists server-side so layouts follow operators across browsers and
// devices; localStorage continues to hold ephemeral UI state (chart
// ranges, theme) per the existing convention.
model UserDashboard {
  userId    String   @id @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  layout    Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("user_dashboards")
}

// Role: identity + permission matrix consulted by the per-route
// `requirePermission(functionKey, level)` middleware. The five seeded
// rows (admin / readonly / networkadmin / assetsadmin / user) reproduce
// the pre-cutover hardcoded UserRole enum's access. `admin` and
// `readonly` are protected (no edit/delete/rename) and hidden from the
// editable list in the UI; the other built-ins are editable. Custom
// roles are operator-created with isBuiltIn = false. Permission shape:
//   { [functionKey]: "none" | "read" | "write" | "fullwrite" }
// See "Roles / RBAC" in CLAUDE.md for the function-key catalogue + the
// access-level ordering. `updatedAt` doubles as the cache-version
// stamp the session snapshot compares against on each request.
model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  permissions Json     @default("{}")
  // Region scope inherited by every user holding this role. Empty =
  // unrestricted. Effective regions for a session are
  // `union(role.regionTags, user.regionTags)`. Storage only; consumers
  // live in a separate change.
  regionTags  String[] @default([]) @map("region_tags")
  isBuiltIn   Boolean  @default(false) @map("is_built_in")
  isProtected Boolean  @default(false) @map("is_protected")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]

  @@map("roles")
}

