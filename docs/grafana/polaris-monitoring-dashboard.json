{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Polaris monitor pass health, probe latency by transport, queue depth, process health, plus the 8 bottleneck-spotting metric families (DB pool, capacity, pg-boss age, discovery, sample writes, HTTP, jobs).",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "panels": [],
      "title": "Fleet overview",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_monitored_assets", "legendFormat": "monitored", "refId": "A" }
      ],
      "title": "Monitored assets",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "up" },      "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "down" },    "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "unknown" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 1 },
      "id": 2,
      "options": { "displayLabels": ["name", "percent"], "legend": { "displayMode": "list", "placement": "right", "showLegend": true }, "pieType": "donut" },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_monitored_assets_by_status", "legendFormat": "{{status}}", "refId": "A" }
      ],
      "title": "Assets by monitor status",
      "type": "piechart"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.95 },
              { "color": "green", "value": 0.99 }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 4, "w": 9, "x": 15, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        {
          "expr": "sum(rate(polaris_probe_total{outcome=\"success\"}[5m])) / clamp_min(sum(rate(polaris_probe_total[5m])), 0.001)",
          "legendFormat": "success rate",
          "refId": "A"
        }
      ],
      "title": "Probe success rate (5m)",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 5 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_monitored_assets_by_status{status=\"down\"}", "legendFormat": "down", "refId": "A" }
      ],
      "title": "Assets currently down",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "unit": "ops", "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
      },
      "gridPos": { "h": 4, "w": 9, "x": 15, "y": 5 },
      "id": 5,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "sum(rate(polaris_probe_total[1m]))", "legendFormat": "probes/sec", "refId": "A" }
      ],
      "title": "Probe rate (per second)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "panels": [],
      "title": "Cadence health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p50 / p95 / p99 wall-clock of one runMonitorPass call. Watch this rise toward the configured cadence as a saturation signal — when p99 approaches your monitor.intervalSeconds, the pool is falling behind.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le) (rate(polaris_monitor_pass_duration_seconds_bucket[5m])))", "legendFormat": "p50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, sum by (le) (rate(polaris_monitor_pass_duration_seconds_bucket[5m])))", "legendFormat": "p95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(polaris_monitor_pass_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "C" }
      ],
      "title": "Monitor pass duration (p50 / p95 / p99)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Items queued at the start of each pass, by cadence. Sustained non-zero values mean the pool is producing slower than the publisher.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } } } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_monitor_queue_depth", "legendFormat": "{{cadence}}", "refId": "A" }
      ],
      "title": "Queue depth by cadence",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Per-cadence work outcomes. crash = unhandled exception in the worker (never expected), failure = the work ran but reported a sad-path result, success = clean run.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 18 },
      "id": 8,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (cadence, outcome) (rate(polaris_monitor_work_total[1m]))", "legendFormat": "{{cadence}} {{outcome}}", "refId": "A" }
      ],
      "title": "Work item rate by cadence + outcome",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 26 },
      "id": 102,
      "panels": [],
      "title": "Probe latency by transport",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 probe wall-clock by transport. Compare across fortimanager / fortigate / snmp / winrm / ssh / icmp / activedirectory to spot transport-specific slowness.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 27 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, transport) (rate(polaris_probe_duration_seconds_bucket[5m])))", "legendFormat": "{{transport}}", "refId": "A" }
      ],
      "title": "Probe duration p95 by transport",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Per-transport probe rate, separated by outcome. Sustained failures on one transport often mean a credential or network issue on a specific integration.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (transport, outcome) (rate(polaris_probe_total[1m]))", "legendFormat": "{{transport}} {{outcome}}", "refId": "A" }
      ],
      "title": "Probe rate by transport + outcome",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 35 },
      "id": 103,
      "panels": [],
      "title": "Process health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Node.js event-loop lag p99. Healthy: under 25 ms. Watch: 25–50 ms. Pressure: 50–100 ms. Saturated: 100 ms+. Polaris tested at 15 ms p99 on the Rogers Group fleet (1844 monitored assets).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "orange", "value": 0.1 }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 36 },
      "id": 11,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "nodejs_eventloop_lag_p99_seconds", "legendFormat": "p99", "refId": "A" },
        { "expr": "nodejs_eventloop_lag_seconds", "legendFormat": "mean", "refId": "B" }
      ],
      "title": "Event loop lag",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Node.js process memory: RSS (total resident) and heap used. Watch heap_used trending up between GC cycles for a memory leak.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 36 },
      "id": 12,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "process_resident_memory_bytes", "legendFormat": "RSS", "refId": "A" },
        { "expr": "nodejs_heap_size_used_bytes", "legendFormat": "heap used", "refId": "B" },
        { "expr": "nodejs_heap_size_total_bytes", "legendFormat": "heap total", "refId": "C" }
      ],
      "title": "Process memory",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Node.js process CPU usage (user + system, summed across the event-loop core). Spikes correlate with discovery sync cycles.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "percentunit" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 36 },
      "id": 13,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "expr": "rate(process_cpu_seconds_total[1m])", "legendFormat": "cpu", "refId": "A" }
      ],
      "title": "Process CPU",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 44 },
      "id": 104,
      "panels": [],
      "title": "Capacity & growth",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Overall capacity severity from capacityService — drives the Maintenance tab pill and the sidebar critical alert. 0=ok, 1=watch (you have weeks), 2=amber (you have days), 3=red (act now).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "mappings": [
            { "options": { "0": { "text": "OK",    "color": "green"  } }, "type": "value" },
            { "options": { "1": { "text": "Watch", "color": "blue"   } }, "type": "value" },
            { "options": { "2": { "text": "Amber", "color": "orange" } }, "type": "value" },
            { "options": { "3": { "text": "Red",   "color": "red"    } }, "type": "value" }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "blue", "value": 1 }, { "color": "orange", "value": 2 }, { "color": "red", "value": 3 }] }
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 45 },
      "id": 14,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_capacity_severity", "legendFormat": "severity", "refId": "A" }
      ],
      "title": "Capacity severity",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "DB connection pool — current in-use, peak observed since boot, Polaris-owned capacity (Prisma + pg-boss pools), Postgres-side max_connections.",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } } },
      "gridPos": { "h": 4, "w": 9, "x": 6, "y": 45 },
      "id": 15,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_db_pool_in_use",            "legendFormat": "in use",   "refId": "A" },
        { "expr": "polaris_db_pool_peak_observed",     "legendFormat": "peak",     "refId": "B" },
        { "expr": "polaris_db_pool_polaris_capacity",  "legendFormat": "capacity", "refId": "C" },
        { "expr": "polaris_db_pool_max",               "legendFormat": "pg max",   "refId": "D" }
      ],
      "title": "DB pool — in use / peak / capacity / max",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "DB pool utilization vs Polaris-owned capacity. peak_observed/polaris_capacity is the actionable line — yellow at 0.7, red at 0.9. When it approaches 1, the app stalls at pool acquisition.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line+area" } },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 45 },
      "id": 16,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_db_pool_peak_observed / clamp_min(polaris_db_pool_polaris_capacity, 1)", "legendFormat": "peak / capacity", "refId": "A" },
        { "expr": "polaris_db_pool_in_use        / clamp_min(polaris_db_pool_polaris_capacity, 1)", "legendFormat": "now / capacity",  "refId": "B" }
      ],
      "title": "DB pool utilization (peak & current vs capacity)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Database size now vs projected steady-state at current cadences and retention. Steady-state is what the DB will grow to *if nothing changes* — the gap between the two lines is your remaining growth runway.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "bytes" } },
      "gridPos": { "h": 4, "w": 15, "x": 0, "y": 49 },
      "id": 17,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_db_size_bytes",              "legendFormat": "current",      "refId": "A" },
        { "expr": "polaris_db_steady_state_size_bytes", "legendFormat": "steady-state", "refId": "B" }
      ],
      "title": "Database size — current vs steady-state",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Free-space ratio per filesystem Polaris/Postgres write to. Pre-deduped by stat.dev. Watch threshold at 30%, amber at 20%, red at 10%.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line+area" } },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }, { "color": "orange", "value": 0.1 }, { "color": "yellow", "value": 0.2 }, { "color": "blue", "value": 0.3 }, { "color": "green", "value": 0.5 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 53 },
      "id": 18,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_disk_free_ratio", "legendFormat": "{{volume}} ({{roles}})", "refId": "A" }
      ],
      "title": "Disk free ratio per volume",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Dead-tuple ratio per sample table. Yellow at 0.2, red at 0.3 — autovacuum is falling behind the insert rate. TimescaleDB hypertables exempt themselves on the capacity reasons side; expect a single non-hypertable line if you've enabled the extension.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line+area" } },
          "max": 1,
          "min": 0,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.2 }, { "color": "red", "value": 0.3 }] },
          "unit": "percentunit"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 53 },
      "id": 19,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_db_dead_tuple_ratio", "legendFormat": "{{table}}", "refId": "A" }
      ],
      "title": "Dead tuple ratio per table",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 61 },
      "id": 105,
      "panels": [],
      "title": "Throughput & queue health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Age of the oldest pg-boss job per queue × state. Pg-boss mode only — stays at 0 in cursor mode. A queue at non-zero depth AND oldest age climbing past ~60s = stalled worker. The watchdog already auto-recovers after 1 min, but the gauge tells you it happened.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "thresholdsStyle": { "mode": "line+area" } },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 60 }, { "color": "red", "value": 300 }] },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 62 },
      "id": 20,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "polaris_pgboss_oldest_job_age_seconds", "legendFormat": "{{queue}} ({{state}})", "refId": "A" }
      ],
      "title": "Pg-boss oldest job age",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 of one bulk write into a sample table. Splits DB-write cost out of the broader monitor work duration so a slow autovacuum / index bloat / lock contention is visible separately from network probe time.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 62 },
      "id": 21,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, table) (rate(polaris_sample_write_duration_seconds_bucket[5m])))", "legendFormat": "{{table}}", "refId": "A" }
      ],
      "title": "Sample-write p95 by table",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 end-to-end discovery wall-clock by integration type, on a 1-hour rolling window (discovery cycles are minutes-long, so a 5m window doesn't have enough samples). 'Is discovery getting slower as we add more devices?' as a graph.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 70 },
      "id": 22,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, integration_type) (rate(polaris_discovery_duration_seconds_bucket[1h])))", "legendFormat": "{{integration_type}}", "refId": "A" }
      ],
      "title": "Discovery duration p95 by integration type (1h window)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Discovery runs by integration type and outcome. Failure rate climbing on one integration usually means preflight credentials / connectivity. Aborted means the operator hit the cancel button (or another discovery superseded a stuck one).",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "bars", "lineWidth": 1, "fillOpacity": 80, "stacking": { "mode": "normal" } }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 70 },
      "id": 23,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (integration_type, outcome) (rate(polaris_discovery_total[1h]))", "legendFormat": "{{integration_type}} {{outcome}}", "refId": "A" }
      ],
      "title": "Discovery rate by integration + outcome",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 78 },
      "id": 106,
      "panels": [],
      "title": "HTTP latency",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 HTTP request duration, top-10 routes by max latency over the window. /metrics + /health are excluded from the source data. Climbing across all routes ≈ DB pool exhausted; climbing on one route = that handler is hanging.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 79 },
      "id": 24,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, sum by (le, route) (rate(polaris_http_request_duration_seconds_bucket[5m]))))", "legendFormat": "{{route}}", "refId": "A" }
      ],
      "title": "HTTP p95 by route (top 10)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "HTTP requests currently being handled by the Polaris process. Climbing under monitor load = handler backpressure. Combined with DB pool utilization above, this tells you whether the backpressure is in HTTP or DB.",
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 25 }, { "color": "red", "value": 100 }] } } },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 79 },
      "id": 25,
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false } },
      "pluginVersion": "9.0.0",
      "targets": [
        { "expr": "polaris_http_in_flight", "legendFormat": "in flight", "refId": "A" }
      ],
      "title": "HTTP in-flight",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Request rate by HTTP status class. 5xx > 0 means the application threw an unhandled error (errorHandler caught it); 4xx is mostly auth/CSRF rejects (some background level expected during page navigations).",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10, "stacking": { "mode": "normal" } }, "unit": "ops" } },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 83 },
      "id": 26,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (status_class) (rate(polaris_http_request_duration_seconds_count[5m]))", "legendFormat": "{{status_class}}", "refId": "A" }
      ],
      "title": "HTTP rate by status class",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 87 },
      "id": 107,
      "panels": [],
      "title": "Job health",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "p95 duration of one tick of each scheduled background job. Watch a job's line approach its tick interval (60s for dependencyReconciler, 30s for monitorAssets.heavy, 5s for monitorAssets.probe, 6h for reconcileMapRegions) — that's the early-warning that scheduled work is lagging.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "s" } },
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 88 },
      "id": 27,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["max"] }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, job) (rate(polaris_job_duration_seconds_bucket[15m])))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "title": "Job duration p95 by job",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Job tick failure rate, by job. Sustained failures on one job = its downstream dependency (DB connection, FMG, an external service) is broken; check the corresponding pino logs by `job` value.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "lineWidth": 2, "fillOpacity": 10 }, "unit": "ops" } },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 88 },
      "id": 28,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum by (job) (rate(polaris_job_total{outcome=\"failure\"}[15m]))", "legendFormat": "{{job}}", "refId": "A" }
      ],
      "title": "Job failure rate",
      "type": "timeseries"
    }
